<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• FIXFOX LIGHT PALETTE â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->
  <!-- Background layers -->
  <SolidColorBrush x:Key="BgPrimaryBrush"   Color="#EEF0F4"/>
  <SolidColorBrush x:Key="BgSurfaceBrush"   Color="#FAFBFD"/>
  <SolidColorBrush x:Key="BgCardBrush"      Color="#FFFFFF"/>
  <SolidColorBrush x:Key="BgCard2Brush"     Color="#F4F6FA"/>
  <SolidColorBrush x:Key="BorderBrush"      Color="#DDE1EA"/>

  <!-- Text -->
  <SolidColorBrush x:Key="TextPrimaryBrush" Color="#1A2035"/>
  <SolidColorBrush x:Key="TextSecBrush"     Color="#5A6577"/>
  <SolidColorBrush x:Key="TextMutedBrush"   Color="#A0AABB"/>

  <!-- FixFox brand â€” fox orange (identical in both themes) -->
  <SolidColorBrush x:Key="FoxOrangeBrush"      Color="#E8720C"/>
  <SolidColorBrush x:Key="FoxOrangeDimBrush"   Color="#B85A09"/>
  <SolidColorBrush x:Key="FoxOrangeGlowBrush"  Color="#14E8720C"/>

  <!-- Accents -->
  <SolidColorBrush x:Key="AccentBlueBrush"   Color="#3B82F6"/>
  <SolidColorBrush x:Key="AccentBlue2Brush"  Color="#2563EB"/>
  <SolidColorBrush x:Key="AccentGreenBrush"  Color="#16A34A"/>
  <SolidColorBrush x:Key="AccentAmberBrush"  Color="#D97706"/>
  <SolidColorBrush x:Key="AccentRedBrush"    Color="#DC2626"/>
  <SolidColorBrush x:Key="AccentPurpleBrush" Color="#7C3AED"/>

  <!-- Button interactive states -->
  <SolidColorBrush x:Key="ButtonHoverBrush"      Color="#E8ECF2"/>
  <SolidColorBrush x:Key="ButtonPressedBrush"    Color="#D8DDE8"/>
  <SolidColorBrush x:Key="SecBtnHoverBrush"      Color="#EBEEF5"/>
  <SolidColorBrush x:Key="TitleBarBrush"         Color="#FAFBFD"/>
  <SolidColorBrush x:Key="StatusBarBrush"        Color="#F0F2F6"/>
  <SolidColorBrush x:Key="WindowBorderBrush"     Color="#C8CDD8"/>

  <!-- Icon font (Segoe Fluent Icons, falling back to MDL2 Assets) -->
  <FontFamily x:Key="IconFont">Segoe Fluent Icons, Segoe MDL2 Assets</FontFamily>

  <!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• GLOBAL DEFAULTS â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->
  <Style TargetType="TextBlock">
    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
    <Setter Property="FontFamily" Value="Segoe UI"/>
  </Style>

  <Style TargetType="TextBox">
    <Setter Property="Background"      Value="{StaticResource BgCardBrush}"/>
    <Setter Property="Foreground"      Value="{StaticResource TextPrimaryBrush}"/>
    <Setter Property="CaretBrush"      Value="{StaticResource FoxOrangeBrush}"/>
    <Setter Property="BorderBrush"     Value="{StaticResource BorderBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Padding"         Value="10,7"/>
    <Setter Property="FontFamily"      Value="Segoe UI"/>
    <Setter Property="FontSize"        Value="13"/>
    <Setter Property="SelectionBrush"  Value="{StaticResource FoxOrangeBrush}"/>
    <Style.Triggers>
      <Trigger Property="IsFocused" Value="True">
        <Setter Property="BorderBrush" Value="{StaticResource FoxOrangeBrush}"/>
      </Trigger>
    </Style.Triggers>
  </Style>

  <Style TargetType="ContextMenu">
    <Setter Property="Background" Value="{StaticResource BgCardBrush}"/>
    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Padding" Value="4"/>
  </Style>

  <Style TargetType="MenuItem">
    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="Padding" Value="10,6"/>
    <Setter Property="Margin" Value="2"/>
    <Style.Triggers>
      <Trigger Property="IsHighlighted" Value="True">
        <Setter Property="Background" Value="{StaticResource BgCard2Brush}"/>
      </Trigger>
    </Style.Triggers>
  </Style>

  <Style TargetType="CheckBox">
    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
    <Setter Property="VerticalContentAlignment" Value="Center"/>
  </Style>

  <Style TargetType="Separator">
    <Setter Property="Background" Value="{StaticResource BorderBrush}"/>
    <Setter Property="Height"     Value="1"/>
    <Setter Property="Margin"     Value="0"/>
  </Style>

  <!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• SCROLLBAR â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->
  <Style TargetType="ScrollBar">
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="Width"      Value="5"/>
    <Setter Property="Opacity"    Value="0"/>
    <Style.Triggers>
      <Trigger Property="IsMouseOver" Value="True">
        <Setter Property="Opacity" Value="1"/>
        <Setter Property="Width"   Value="6"/>
      </Trigger>
    </Style.Triggers>
  </Style>

  <Style TargetType="ScrollViewer">
    <Setter Property="VerticalScrollBarVisibility"   Value="Auto"/>
    <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
  </Style>

  <!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• SIDEBAR NAV BUTTON â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->
  <Style x:Key="NavButton" TargetType="Button">
    <Setter Property="Background"                 Value="Transparent"/>
    <Setter Property="Foreground"                 Value="{StaticResource TextSecBrush}"/>
    <Setter Property="BorderThickness"            Value="0"/>
    <Setter Property="HorizontalAlignment"        Value="Stretch"/>
    <Setter Property="HorizontalContentAlignment" Value="Left"/>
    <Setter Property="Padding"                    Value="14,11,14,11"/>
    <Setter Property="Margin"                     Value="6,1"/>
    <Setter Property="FontSize"                   Value="13"/>
    <Setter Property="FontFamily"                 Value="Segoe UI"/>
    <Setter Property="Cursor"                     Value="Hand"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="bg" Background="{TemplateBinding Background}"
                  CornerRadius="7" Padding="{TemplateBinding Padding}">
            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                              VerticalAlignment="Center"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="bg" Property="Background" Value="{StaticResource FoxOrangeGlowBrush}"/>
              <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
              <Setter TargetName="bg" Property="Background" Value="#20E8720C"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="NavButtonActive" TargetType="Button" BasedOn="{StaticResource NavButton}">
    <Setter Property="Background" Value="{StaticResource FoxOrangeGlowBrush}"/>
    <Setter Property="Foreground" Value="{StaticResource FoxOrangeBrush}"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
  </Style>

  <Style x:Key="CategoryButton" TargetType="Button" BasedOn="{StaticResource NavButton}">
    <Setter Property="FontSize" Value="12"/>
    <Setter Property="Padding"  Value="14,8,14,8"/>
  </Style>

  <!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• PRIMARY BUTTON â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->
  <Style x:Key="PrimaryButton" TargetType="Button">
    <Setter Property="Background"      Value="{StaticResource FoxOrangeBrush}"/>
    <Setter Property="Foreground"      Value="White"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="MinWidth"        Value="92"/>
    <Setter Property="MinHeight"       Value="36"/>
    <Setter Property="Padding"         Value="16,8"/>
    <Setter Property="FontSize"        Value="13"/>
    <Setter Property="FontWeight"      Value="SemiBold"/>
    <Setter Property="FontFamily"      Value="Segoe UI"/>
    <Setter Property="Cursor"          Value="Hand"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="bg" Background="{TemplateBinding Background}"
                  CornerRadius="8" Padding="{TemplateBinding Padding}"
                  MinHeight="{TemplateBinding MinHeight}">
            <ContentPresenter HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              RecognizesAccessKey="True"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="bg" Property="Background" Value="{StaticResource FoxOrangeDimBrush}"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
              <Setter TargetName="bg" Property="Background" Value="#A05508"/>
            </Trigger>
            <Trigger Property="IsKeyboardFocused" Value="True">
              <Setter TargetName="bg" Property="BorderBrush" Value="#FFF0B27A"/>
              <Setter TargetName="bg" Property="BorderThickness" Value="1"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter TargetName="bg" Property="Background" Value="{StaticResource BgCard2Brush}"/>
              <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="FixButton"  TargetType="Button" BasedOn="{StaticResource PrimaryButton}"/>
  <Style x:Key="ScanButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}"/>

  <!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• SECONDARY BUTTON â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->
  <Style x:Key="SecondaryButton" TargetType="Button">
    <Setter Property="Background"      Value="{StaticResource BgCard2Brush}"/>
    <Setter Property="Foreground"      Value="{StaticResource TextPrimaryBrush}"/>
    <Setter Property="BorderBrush"     Value="{StaticResource BorderBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="MinWidth"        Value="92"/>
    <Setter Property="MinHeight"       Value="36"/>
    <Setter Property="Padding"         Value="14,7"/>
    <Setter Property="FontSize"        Value="12"/>
    <Setter Property="FontFamily"      Value="Segoe UI"/>
    <Setter Property="Cursor"          Value="Hand"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="bg" Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  CornerRadius="8" Padding="{TemplateBinding Padding}"
                  MinHeight="{TemplateBinding MinHeight}">
            <ContentPresenter HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              RecognizesAccessKey="True"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="bg" Property="Background" Value="{StaticResource ButtonHoverBrush}"/>
              <Setter TargetName="bg" Property="BorderBrush" Value="{StaticResource FoxOrangeBrush}"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
              <Setter TargetName="bg" Property="Background" Value="{StaticResource ButtonPressedBrush}"/>
            </Trigger>
            <Trigger Property="IsKeyboardFocused" Value="True">
              <Setter TargetName="bg" Property="BorderBrush" Value="{StaticResource FoxOrangeBrush}"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter TargetName="bg" Property="Background" Value="{StaticResource BgCardBrush}"/>
              <Setter TargetName="bg" Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
              <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
    <Setter Property="Foreground" Value="{StaticResource AccentRedBrush}"/>
    <Setter Property="BorderBrush" Value="{StaticResource AccentRedBrush}"/>
  </Style>

  <!-- Icon-only button for title bar controls -->
  <Style x:Key="IconButton" TargetType="Button">
    <Setter Property="Background"      Value="Transparent"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="Width"           Value="46"/>
    <Setter Property="Height"          Value="44"/>
    <Setter Property="FontFamily"      Value="{StaticResource IconFont}"/>
    <Setter Property="FontSize"        Value="10"/>
    <Setter Property="Foreground"      Value="{StaticResource TextSecBrush}"/>
    <Setter Property="Cursor"          Value="Hand"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="bg" Background="{TemplateBinding Background}">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="bg" Property="Background" Value="{StaticResource ButtonHoverBrush}"/>
              <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
              <Setter TargetName="bg" Property="Background" Value="{StaticResource ButtonPressedBrush}"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="CloseButton" TargetType="Button" BasedOn="{StaticResource IconButton}">
    <Style.Triggers>
      <Trigger Property="IsMouseOver" Value="True">
        <Setter Property="Background" Value="#C42B1C"/>
        <Setter Property="Foreground" Value="White"/>
      </Trigger>
    </Style.Triggers>
  </Style>

  <!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• CARDS â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->
  <Style x:Key="FixCard" TargetType="Border">
    <Setter Property="Background"      Value="{StaticResource BgCardBrush}"/>
    <Setter Property="BorderBrush"     Value="{StaticResource BorderBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius"    Value="9"/>
    <Setter Property="Padding"         Value="18,14"/>
    <Setter Property="Margin"          Value="0,0,0,8"/>
  </Style>

  <Style x:Key="InfoCard" TargetType="Border">
    <Setter Property="Background"      Value="{StaticResource BgCardBrush}"/>
    <Setter Property="BorderBrush"     Value="{StaticResource BorderBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius"    Value="9"/>
    <Setter Property="Padding"         Value="18,16"/>
    <Setter Property="Margin"          Value="0,0,12,12"/>
  </Style>

  <!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• METRIC BAR â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->
  <Style x:Key="MetricBar" TargetType="ProgressBar">
    <Setter Property="Height"          Value="5"/>
    <Setter Property="Margin"          Value="0,7,0,4"/>
    <Setter Property="Background"      Value="{StaticResource BgCard2Brush}"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ProgressBar">
          <Border CornerRadius="3" Background="{TemplateBinding Background}" Height="5">
            <Border x:Name="PART_Track" CornerRadius="3">
              <Border x:Name="PART_Indicator" CornerRadius="3"
                      Background="{TemplateBinding Foreground}"
                      HorizontalAlignment="Left"/>
            </Border>
          </Border>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="BundleProgressBar" TargetType="ProgressBar" BasedOn="{StaticResource MetricBar}">
    <Setter Property="Height"  Value="8"/>
    <Setter Property="Margin"  Value="0,10,0,6"/>
    <Setter Property="Foreground" Value="{StaticResource FoxOrangeBrush}"/>
  </Style>

  <Style x:Key="IndeterminateBar" TargetType="ProgressBar">
    <Setter Property="Height"          Value="3"/>
    <Setter Property="IsIndeterminate" Value="True"/>
    <Setter Property="Background"      Value="Transparent"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="Foreground"      Value="{StaticResource FoxOrangeBrush}"/>
  </Style>

  <Style x:Key="CompactStatusBadge" TargetType="Border">
    <Setter Property="Background" Value="{StaticResource BgCard2Brush}"/>
    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="999"/>
    <Setter Property="Padding" Value="8,4"/>
  </Style>

  <Style x:Key="CompactStatusText" TargetType="TextBlock">
    <Setter Property="FontSize" Value="10"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="Foreground" Value="{StaticResource TextSecBrush}"/>
  </Style>

  <Style x:Key="CompactStatusDot" TargetType="Ellipse">
    <Setter Property="Width" Value="7"/>
    <Setter Property="Height" Value="7"/>
    <Setter Property="Fill" Value="{StaticResource TextMutedBrush}"/>
    <Setter Property="Opacity" Value="0.9"/>
    <Style.Triggers>
      <DataTrigger Binding="{Binding IsRunning}" Value="True">
        <Setter Property="Fill" Value="{StaticResource FoxOrangeBrush}"/>
        <DataTrigger.EnterActions>
          <BeginStoryboard x:Name="PulseDotStoryboard">
            <Storyboard RepeatBehavior="Forever" AutoReverse="True">
              <DoubleAnimation Storyboard.TargetProperty="Opacity" From="1" To="0.35" Duration="0:0:0.7"/>
            </Storyboard>
          </BeginStoryboard>
        </DataTrigger.EnterActions>
        <DataTrigger.ExitActions>
          <StopStoryboard BeginStoryboardName="PulseDotStoryboard"/>
        </DataTrigger.ExitActions>
      </DataTrigger>
      <DataTrigger Binding="{Binding IsSucceeded}" Value="True">
        <Setter Property="Fill" Value="{StaticResource AccentGreenBrush}"/>
      </DataTrigger>
      <DataTrigger Binding="{Binding IsFailed}" Value="True">
        <Setter Property="Fill" Value="{StaticResource AccentRedBrush}"/>
      </DataTrigger>
    </Style.Triggers>
  </Style>

  <!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• TEXT LABEL STYLES â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->
  <Style x:Key="CardLabel" TargetType="TextBlock">
    <Setter Property="FontSize"   Value="10"/>
    <Setter Property="FontWeight" Value="Bold"/>
    <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
    <Setter Property="Margin"     Value="0,0,0,6"/>
  </Style>

  <Style x:Key="CardValue" TargetType="TextBlock">
    <Setter Property="FontSize"   Value="14"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
    <Setter Property="TextWrapping" Value="Wrap"/>
  </Style>

  <Style x:Key="CardSub" TargetType="TextBlock">
    <Setter Property="FontSize"   Value="11"/>
    <Setter Property="Foreground" Value="{StaticResource TextSecBrush}"/>
    <Setter Property="Margin"     Value="0,3,0,0"/>
    <Setter Property="TextWrapping" Value="Wrap"/>
    <Setter Property="LineStackingStrategy" Value="BlockLineHeight"/>
    <Setter Property="LineHeight" Value="16"/>
  </Style>

  <Style x:Key="PageTitle" TargetType="TextBlock">
    <Setter Property="FontSize"   Value="20"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
  </Style>

  <Style x:Key="PageSubtitle" TargetType="TextBlock">
    <Setter Property="FontSize"   Value="12"/>
    <Setter Property="Foreground" Value="{StaticResource TextSecBrush}"/>
    <Setter Property="Margin"     Value="0,3,0,0"/>
    <Setter Property="TextWrapping" Value="Wrap"/>
    <Setter Property="LineStackingStrategy" Value="BlockLineHeight"/>
    <Setter Property="LineHeight" Value="17"/>
  </Style>

  <Style x:Key="PanelTitle" TargetType="TextBlock">
    <Setter Property="FontSize"   Value="15"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
  </Style>

  <Style x:Key="MetaText" TargetType="TextBlock">
    <Setter Property="FontSize"   Value="11"/>
    <Setter Property="Foreground" Value="{StaticResource TextSecBrush}"/>
    <Setter Property="LineStackingStrategy" Value="BlockLineHeight"/>
    <Setter Property="LineHeight" Value="16"/>
  </Style>

  <Style x:Key="SectionLabel" TargetType="TextBlock">
    <Setter Property="FontSize"   Value="9"/>
    <Setter Property="FontWeight" Value="Bold"/>
    <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
    <Setter Property="Margin"     Value="20,10,0,2"/>
  </Style>

  <!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• SEARCH BOX â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->
  <Style x:Key="SearchBox" TargetType="Border">
    <Setter Property="Background"      Value="{StaticResource BgCardBrush}"/>
    <Setter Property="BorderBrush"     Value="{StaticResource BorderBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius"    Value="8"/>
    <Setter Property="Padding"         Value="12,0"/>
    <Setter Property="MinHeight"       Value="38"/>
  </Style>

  <!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• STAT PILL â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->
  <Style x:Key="StatPill" TargetType="Border">
    <Setter Property="CornerRadius"    Value="9"/>
    <Setter Property="Padding"         Value="16,12"/>
    <Setter Property="Margin"          Value="0,0,10,0"/>
    <Setter Property="Background"      Value="{StaticResource BgCardBrush}"/>
    <Setter Property="BorderBrush"     Value="{StaticResource BorderBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
  </Style>

  <!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• WPF-UI COMPATIBILITY ALIASES â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->

  <!-- NavButtonStyle â€” sidebar navigation button -->
  <Style x:Key="NavButtonStyle" TargetType="Button" BasedOn="{StaticResource NavButton}"/>

  <!-- SectionLabelStyle â€” sidebar section header label -->
  <Style x:Key="SectionLabelStyle" TargetType="TextBlock" BasedOn="{StaticResource SectionLabel}"/>

  <!-- AccentButtonStyle â€” primary call-to-action (fox orange) -->
  <Style x:Key="AccentButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButton}"/>

  <!-- TitleBarButtonStyle â€” min/max chrome buttons -->
  <Style x:Key="TitleBarButtonStyle" TargetType="Button" BasedOn="{StaticResource IconButton}">
    <Setter Property="Height"   Value="48"/>
    <Setter Property="Width"    Value="46"/>
    <Setter Property="FontSize" Value="10"/>
  </Style>

  <!-- TitleBarCloseButtonStyle â€” close chrome button (red on hover) -->
