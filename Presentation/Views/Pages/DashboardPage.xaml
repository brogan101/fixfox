<Page x:Class="HelpDesk.Presentation.Views.Pages.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:h="clr-namespace:HelpDesk.Presentation.Helpers"
      xmlns:m="clr-namespace:HelpDesk.Domain.Models"
      Background="{DynamicResource BgPrimaryBrush}">

  <Page.Resources>
    <h:BoolToVisConverter      x:Key="BoolVis"/>
    <h:InverseBoolToVisConverter x:Key="InvBoolVis"/>
    <h:SeverityColorConverter  x:Key="SevColor"/>
    <h:SeverityIconConverter   x:Key="SeverityIcon"/>
    <h:StatusIconConverter     x:Key="StatusIcon"/>
    <h:RunningVisConverter     x:Key="RunningVis"/>
    <h:NullToCollapsedConverter x:Key="NullCollapsed"/>
  </Page.Resources>

  <ScrollViewer>
    <Grid Margin="28,24">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
      </Grid.RowDefinitions>

      <!-- Page header -->
      <StackPanel Grid.Row="0" Margin="0,0,0,20">
        <TextBlock Text="Dashboard" Style="{DynamicResource PageTitle}"/>
        <TextBlock Text="Your PC health at a glance" Style="{DynamicResource PageSubtitle}"/>
      </StackPanel>

      <!-- Scan status bar -->
      <ProgressBar Grid.Row="1" IsIndeterminate="True" Height="3"
                   Foreground="{DynamicResource FoxOrangeBrush}"
                   Background="Transparent" BorderThickness="0"
                   Visibility="{Binding ScanRunning, Converter={StaticResource BoolVis}}"
                   Margin="0,0,0,8"/>

      <!-- Summary pills -->
      <WrapPanel Grid.Row="2" Margin="0,0,0,20">
        <Border Style="{DynamicResource StatPill}">
          <StackPanel>
            <TextBlock Text="Health" Style="{DynamicResource CardLabel}"/>
            <TextBlock Text="{Binding OverallHealth}" Style="{DynamicResource CardValue}"
                       Foreground="{Binding OverallHealthColor}"/>
          </StackPanel>
        </Border>
        <Border Style="{DynamicResource StatPill}">
          <StackPanel>
            <TextBlock Text="CRITICAL" Style="{DynamicResource CardLabel}"
                       Foreground="{DynamicResource AccentRedBrush}"/>
            <TextBlock Text="{Binding ScanCriticalCount}" Style="{DynamicResource CardValue}"/>
          </StackPanel>
        </Border>
        <Border Style="{DynamicResource StatPill}">
          <StackPanel>
            <TextBlock Text="WARNINGS" Style="{DynamicResource CardLabel}"
                       Foreground="{DynamicResource AccentAmberBrush}"/>
            <TextBlock Text="{Binding ScanWarningCount}" Style="{DynamicResource CardValue}"/>
          </StackPanel>
        </Border>
        <Border Style="{DynamicResource StatPill}">
          <StackPanel>
            <TextBlock Text="OK" Style="{DynamicResource CardLabel}"
                       Foreground="{DynamicResource AccentGreenBrush}"/>
            <TextBlock Text="{Binding ScanGoodCount}" Style="{DynamicResource CardValue}"/>
          </StackPanel>
        </Border>
        <Border Style="{DynamicResource StatPill}">
          <StackPanel>
            <TextBlock Text="STATUS" Style="{DynamicResource CardLabel}"/>
            <TextBlock Text="{Binding ScanStatusText}" Style="{DynamicResource CardSub}"
                       MaxWidth="220" TextTrimming="CharacterEllipsis"/>
          </StackPanel>
        </Border>
      </WrapPanel>

      <!-- Content grid -->
      <Grid Grid.Row="3">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <!-- Scan results -->
        <Border Grid.Column="0" Style="{DynamicResource InfoCard}" Margin="0,0,16,0">
          <DockPanel>
            <DockPanel DockPanel.Dock="Top" Margin="0,0,0,14">
              <TextBlock Text="Quick Scan Results" Style="{DynamicResource PageTitle}" FontSize="15" DockPanel.Dock="Left"/>
              <Button Content="Run Scan" Click="RunScan_Click"
                      Style="{DynamicResource AccentButtonStyle}"
                      DockPanel.Dock="Right" HorizontalAlignment="Right"
                      IsEnabled="{Binding ScanRunning, Converter={StaticResource InvBoolVis}}"/>
            </DockPanel>

            <TextBlock DockPanel.Dock="Top" Text="{Binding ScanStatusText}"
                       Style="{DynamicResource CardSub}" Margin="0,0,0,10"
                       Visibility="{Binding ScanRunning, Converter={StaticResource InvBoolVis}}"/>

            <ScrollViewer>
              <ItemsControl ItemsSource="{Binding ScanResults}"
                            VirtualizingStackPanel.IsVirtualizing="True">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate><VirtualizingStackPanel/></ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate DataType="{x:Type m:ScanResult}">
                    <Border Style="{DynamicResource FixCard}">
                      <DockPanel>
                        <TextBlock DockPanel.Dock="Left"
                                   Text="{Binding Severity, Converter={StaticResource SeverityIcon}}"
                                   FontFamily="{DynamicResource IconFont}" FontSize="16"
                                   Foreground="{Binding Severity, Converter={StaticResource SevColor}}"
                                   VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <Button DockPanel.Dock="Right" Content="Fix it" Tag="{Binding}"
                                Click="ScanFix_Click" Style="{DynamicResource PrimaryButton}"
                                Visibility="{Binding FixId, Converter={StaticResource NullCollapsed}}"
                                VerticalAlignment="Center"/>
                        <StackPanel>
                          <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="13"/>
                          <TextBlock Text="{Binding Detail}" Style="{DynamicResource CardSub}"
                                     TextWrapping="Wrap"/>
                        </StackPanel>
                      </DockPanel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
          </DockPanel>
        </Border>

        <!-- Recently run + wizard -->
        <StackPanel Grid.Column="1">
          <Border Style="{DynamicResource InfoCard}" Margin="0,0,0,12">
            <StackPanel>
              <TextBlock Text="Recommended Next Steps" Style="{DynamicResource PageTitle}" FontSize="14" Margin="0,0,0,10"/>
              <ItemsControl ItemsSource="{Binding ProactiveRecommendations}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate DataType="{x:Type m:ProactiveRecommendation}">
                    <Border Style="{DynamicResource FixCard}" Padding="12,10">
                      <StackPanel>
                        <TextBlock Text="{Binding Title}" FontSize="12" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding Summary}" Style="{DynamicResource CardSub}" TextWrapping="Wrap" FontSize="11"/>
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
              <TextBlock Text="Run a scan to refresh recommendations." Style="{DynamicResource CardSub}"
                         Visibility="{Binding ProactiveRecommendations.Count, Converter={StaticResource NullCollapsed}}"/>
            </StackPanel>
          </Border>

          <!-- Recently Run -->
          <Border Style="{DynamicResource InfoCard}" Margin="0,0,0,12">
            <StackPanel>
              <TextBlock Text="Recently Run" Style="{DynamicResource PageTitle}" FontSize="14" Margin="0,0,0,10"/>
              <ItemsControl ItemsSource="{Binding RecentlyRunFixes}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate DataType="{x:Type m:FixItem}">
                    <Border Style="{DynamicResource FixCard}" Padding="12,10">
                      <StackPanel>
                        <TextBlock Text="{Binding Title}" FontSize="12" FontWeight="Medium"/>
                        <TextBlock Text="{Binding Status}" Style="{DynamicResource CardSub}" FontSize="11"/>
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
              <TextBlock Text="No fixes run yet" Style="{DynamicResource CardSub}"
                         Visibility="{Binding RecentlyRunFixes.Count, Converter={StaticResource NullCollapsed}}"/>
            </StackPanel>
          </Border>

          <!-- Wizard panel -->
          <Border Style="{DynamicResource InfoCard}"
                  Visibility="{Binding WizardVisible, Converter={StaticResource BoolVis}}">
            <StackPanel>
              <TextBlock Text="{Binding WizardFix.Title}" FontWeight="Bold" FontSize="14" Margin="0,0,0,4"/>
              <TextBlock Text="{Binding WizardStepLabel}" Style="{DynamicResource CardSub}" Margin="0,0,0,10"/>
              <TextBlock Text="{Binding CurrentStep.Instruction}" Style="{DynamicResource CardSub}"
                         TextWrapping="Wrap" Margin="0,0,0,12"/>
              <WrapPanel>
                <Button Content="{Binding WizardNextLabel}" Click="WizardNext_Click"
                        Style="{DynamicResource AccentButtonStyle}" Margin="0,0,8,0"/>
                <Button Content="Cancel" Click="WizardCancel_Click"
                        Style="{DynamicResource SecondaryButton}"/>
              </WrapPanel>
            </StackPanel>
          </Border>
        </StackPanel>
      </Grid>
    </Grid>
  </ScrollViewer>
</Page>
