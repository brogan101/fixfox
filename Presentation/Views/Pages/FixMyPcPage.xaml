<Page x:Class="HelpDesk.Presentation.Views.Pages.FixMyPcPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:h="clr-namespace:HelpDesk.Presentation.Helpers"
      xmlns:m="clr-namespace:HelpDesk.Domain.Models"
      xmlns:automation="clr-namespace:System.Windows.Automation;assembly=PresentationCore"
      Background="{DynamicResource BgPrimaryBrush}">

  <Page.Resources>
    <h:BoolToVisConverter x:Key="BoolVis"/>
    <h:InverseBoolToVisConverter x:Key="InvBoolVis"/>
    <h:RelativeDateConverter x:Key="RelDate"/>
  </Page.Resources>

  <Grid Margin="28,24">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="20"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="20"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <StackPanel Grid.Row="0">
      <TextBlock Text="Fix My PC"
                 Style="{DynamicResource PageTitle}"
                 automation:AutomationProperties.AutomationId="FixMyPCPageMarker"/>
      <TextBlock Text="Pick the problem that feels closest to what is happening. FixFox will show the safest next step in plain English."
                 Style="{DynamicResource PageSubtitle}"
                 TextWrapping="Wrap"/>
    </StackPanel>

    <Border Grid.Row="2"
            Style="{DynamicResource InfoCard}">
      <StackPanel>
        <TextBlock Text="What's wrong with your PC?"
                   Style="{DynamicResource PanelTitle}"/>
        <TextBlock Text="Choose the problem you want help with. If you're not sure, pick the closest match."
                   Style="{DynamicResource CardSub}"
                   Margin="0,6,0,16"
                   TextWrapping="Wrap"/>
        <ItemsControl ItemsSource="{Binding PrimarySimplifiedProblemOptions}">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <UniformGrid Columns="5"/>
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate DataType="{x:Type m:SimplifiedProblemOption}">
              <Button Tag="{Binding}"
                      Click="ProblemButton_Click"
                      Margin="0,0,12,12"
                      Padding="16,14"
                      MinHeight="116"
                      Style="{DynamicResource SecondaryButton}"
                      automation:AutomationProperties.AutomationId="{Binding AutomationId}">
                <StackPanel>
                  <TextBlock Text="{Binding Glyph}"
                             FontFamily="{DynamicResource IconFont}"
                             FontSize="22"
                             HorizontalAlignment="Left"/>
                  <TextBlock Text="{Binding Title}"
                             Margin="0,10,0,6"
                             FontWeight="SemiBold"
                             FontSize="13"
                             TextWrapping="Wrap"/>
                  <TextBlock Text="{Binding Description}"
                             Style="{DynamicResource CardSub}"
                             TextWrapping="Wrap"
                             MaxHeight="34"/>
                </StackPanel>
              </Button>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Button Content="{Binding SimplifiedOtherProblemOption.Title}"
                Tag="{Binding SimplifiedOtherProblemOption}"
                Click="ProblemButton_Click"
                MinHeight="52"
                Style="{DynamicResource AccentButtonStyle}"
                HorizontalAlignment="Left"
                Padding="18,10"
                automation:AutomationProperties.AutomationId="FixMyPC_Problem_Other"/>
      </StackPanel>
    </Border>

    <Border Grid.Row="4"
            Style="{DynamicResource InfoCard}"
            Visibility="{Binding HasSimplifiedRecentQuickActions, Converter={StaticResource BoolVis}}">
      <StackPanel>
        <TextBlock Text="Recently fixed"
                   Style="{DynamicResource PanelTitle}"/>
        <TextBlock Text="Use one of the things that already worked for this PC."
                   Style="{DynamicResource CardSub}"
                   Margin="0,6,0,14"
                   TextWrapping="Wrap"/>
        <ItemsControl ItemsSource="{Binding SimplifiedRecentQuickActions}" AlternationCount="8">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Border Style="{DynamicResource FixCard}" Padding="14,10" Margin="0,0,0,10">
                <DockPanel LastChildFill="False">
                  <Button DockPanel.Dock="Right"
                          Content="Run again"
                          Tag="{Binding}"
                          Click="RecentRunAgain_Click"
                          Style="{DynamicResource AccentButtonStyle}"
                          Margin="12,0,0,0"
                          automation:AutomationProperties.AutomationId="{Binding RelativeSource={RelativeSource AncestorType=ContentPresenter}, Path=(ItemsControl.AlternationIndex), StringFormat=FixMyPC_RecentFix_{0}}"/>
                  <StackPanel>
                    <TextBlock Text="{Binding DisplayTitle}"
                               FontWeight="SemiBold"
                               FontSize="13"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{Binding RelativeTimeText}"
                               Style="{DynamicResource CardSub}"
                               Margin="0,4,0,0"/>
                  </StackPanel>
                </DockPanel>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </StackPanel>
    </Border>
  </Grid>
</Page>
