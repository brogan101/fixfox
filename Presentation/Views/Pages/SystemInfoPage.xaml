<Page x:Class="HelpDesk.Presentation.Views.Pages.SystemInfoPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:h="clr-namespace:HelpDesk.Presentation.Helpers"
      xmlns:m="clr-namespace:HelpDesk.Infrastructure.Services"
      Background="{DynamicResource BgPrimaryBrush}">

  <Page.Resources>
    <h:BoolToVisConverter    x:Key="BoolVis"/>
    <h:InverseBoolToVisConverter x:Key="InvBoolVis"/>
    <h:PercentColorConverter x:Key="PctColor"/>
    <h:NullToCollapsedConverter x:Key="NullCollapsed"/>
  </Page.Resources>

  <ScrollViewer>
    <Grid Margin="28,24">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
      </Grid.RowDefinitions>

      <!-- Header -->
      <DockPanel Grid.Row="0" Margin="0,0,0,20">
        <StackPanel DockPanel.Dock="Left">
          <TextBlock Text="Device Health" Style="{DynamicResource PageTitle}"/>
          <TextBlock Text="Hardware, OS, installed apps, and health signals for technician review." Style="{DynamicResource PageSubtitle}"/>
        </StackPanel>
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
          <Button Content="Refresh Apps" Click="RefreshPrograms_Click"
                  Style="{DynamicResource SecondaryButton}" Margin="0,0,8,0"
                  IsEnabled="{Binding InstalledProgramsLoading, Converter={StaticResource InvBoolVis}}"/>
          <Button Content="Refresh Snapshot" Click="RefreshSysInfo_Click"
                  Style="{DynamicResource AccentButtonStyle}" HorizontalAlignment="Right"
                  IsEnabled="{Binding SnapshotLoading, Converter={StaticResource InvBoolVis}}"/>
        </StackPanel>
      </DockPanel>

      <Border Grid.Row="1" Style="{DynamicResource InfoCard}" Margin="0,0,0,12">
        <TextBlock Text="{Binding HealthCheckSummaryText}" Style="{DynamicResource CardSub}" TextWrapping="Wrap"/>
      </Border>

      <!-- Loading indicator -->
      <ProgressBar Grid.Row="1" IsIndeterminate="True" Height="3"
                   Foreground="{DynamicResource FoxOrangeBrush}"
                   Background="Transparent" BorderThickness="0"
                   Visibility="{Binding SnapshotLoading, Converter={StaticResource BoolVis}}"
                   Margin="0,0,0,12"/>

      <!-- Info grid -->
      <WrapPanel Grid.Row="2">

        <!-- CPU -->
        <Border Style="{DynamicResource InfoCard}" Width="300">
          <StackPanel>
            <TextBlock Text="CPU" Style="{DynamicResource CardLabel}"/>
            <TextBlock Text="{Binding Snapshot.CpuName, FallbackValue='—'}" Style="{DynamicResource CardValue}"/>
            <TextBlock Text="{Binding Snapshot.CpuCores, StringFormat='{}{0} cores', FallbackValue=''}"
                       Style="{DynamicResource CardSub}"/>
            <TextBlock Text="UTILIZATION" Style="{DynamicResource CardLabel}" Margin="0,10,0,0"/>
            <ProgressBar Value="{Binding Snapshot.CpuUsagePct, FallbackValue=0}" Maximum="100"
                         Foreground="{Binding Snapshot.CpuUsagePct, Converter={StaticResource PctColor}}"
                         Style="{DynamicResource MetricBar}"/>
            <TextBlock Foreground="{Binding Snapshot.CpuUsagePct, Converter={StaticResource PctColor}}"
                       FontSize="12">
              <Run Text="{Binding Snapshot.CpuUsagePct, StringFormat='{}{0:N0}', FallbackValue='0'}"/>
              <Run Text="%"/>
            </TextBlock>
          </StackPanel>
        </Border>

        <!-- RAM -->
        <Border Style="{DynamicResource InfoCard}" Width="300">
          <StackPanel>
            <TextBlock Text="MEMORY" Style="{DynamicResource CardLabel}"/>
            <TextBlock Text="{Binding Snapshot.RamTotalMb, StringFormat='{}{0:N0} MB Total', FallbackValue='—'}"
                       Style="{DynamicResource CardValue}"/>
            <TextBlock Text="{Binding Snapshot.RamFreeMb, StringFormat='{}{0:N0} MB free', FallbackValue=''}"
                       Style="{DynamicResource CardSub}"/>
            <TextBlock Text="USAGE" Style="{DynamicResource CardLabel}" Margin="0,10,0,0"/>
            <ProgressBar Value="{Binding Snapshot.RamUsedPct, FallbackValue=0}" Maximum="100"
                         Foreground="{Binding Snapshot.RamUsedPct, Converter={StaticResource PctColor}}"
                         Style="{DynamicResource MetricBar}"/>
            <TextBlock Foreground="{Binding Snapshot.RamUsedPct, Converter={StaticResource PctColor}}"
                       FontSize="12">
              <Run Text="{Binding Snapshot.RamUsedPct, StringFormat='{}{0:N0}', FallbackValue='0'}"/>
              <Run Text="%"/>
            </TextBlock>
          </StackPanel>
        </Border>

        <!-- Disk -->
        <Border Style="{DynamicResource InfoCard}" Width="300">
          <StackPanel>
            <TextBlock Text="DISK C:" Style="{DynamicResource CardLabel}"/>
            <TextBlock Text="{Binding Snapshot.DiskTotalGb, StringFormat='{}{0:N0} GB Total', FallbackValue='—'}"
                       Style="{DynamicResource CardValue}"/>
            <TextBlock Text="{Binding Snapshot.DiskFreeGb, StringFormat='{}{0:N1} GB free', FallbackValue=''}"
                       Style="{DynamicResource CardSub}"/>
            <TextBlock Text="{Binding Snapshot.DiskType, FallbackValue=''}" Style="{DynamicResource CardSub}"/>
            <TextBlock Text="USED" Style="{DynamicResource CardLabel}" Margin="0,10,0,0"/>
            <ProgressBar Value="{Binding Snapshot.DiskUsedPct, FallbackValue=0}" Maximum="100"
                         Foreground="{Binding Snapshot.DiskUsedPct, Converter={StaticResource PctColor}}"
                         Style="{DynamicResource MetricBar}"/>
          </StackPanel>
        </Border>

        <!-- GPU -->
        <Border Style="{DynamicResource InfoCard}" Width="300">
          <StackPanel>
            <TextBlock Text="GPU" Style="{DynamicResource CardLabel}"/>
            <TextBlock Text="{Binding Snapshot.GpuName, FallbackValue='—'}" Style="{DynamicResource CardValue}"/>
            <TextBlock Text="{Binding Snapshot.GpuVramMb, StringFormat='{}{0:N0} MB VRAM', FallbackValue=''}"
                       Style="{DynamicResource CardSub}"/>
          </StackPanel>
        </Border>

        <!-- OS -->
        <Border Style="{DynamicResource InfoCard}" Width="300">
          <StackPanel>
            <TextBlock Text="OPERATING SYSTEM" Style="{DynamicResource CardLabel}"/>
            <TextBlock Text="{Binding Snapshot.OsVersion, FallbackValue='—'}" Style="{DynamicResource CardValue}"/>
            <TextBlock Text="{Binding Snapshot.OsBuild, StringFormat='Build {0}', FallbackValue=''}"
                       Style="{DynamicResource CardSub}"/>
            <TextBlock Text="{Binding Snapshot.Uptime, StringFormat='Uptime: {0}', FallbackValue=''}"
                       Style="{DynamicResource CardSub}"/>
            <TextBlock Text="{Binding Snapshot.MachineName, FallbackValue=''}"
                       Style="{DynamicResource CardSub}"/>
          </StackPanel>
        </Border>

        <!-- Network -->
        <Border Style="{DynamicResource InfoCard}" Width="300">
          <StackPanel>
            <TextBlock Text="NETWORK" Style="{DynamicResource CardLabel}"/>
            <TextBlock Text="{Binding Snapshot.NetworkAdapterName, FallbackValue='—'}"
                       Style="{DynamicResource CardValue}"/>
            <TextBlock Text="{Binding Snapshot.IpAddress, FallbackValue=''}"
                       Style="{DynamicResource CardSub}"/>
            <TextBlock Text="{Binding Snapshot.NetworkType, FallbackValue=''}"
                       Style="{DynamicResource CardSub}"/>
          </StackPanel>
        </Border>

        <!-- Battery (only if present) -->
        <Border Style="{DynamicResource InfoCard}" Width="300"
                Visibility="{Binding Snapshot.HasBattery, Converter={StaticResource BoolVis}}">
          <StackPanel>
            <TextBlock Text="BATTERY" Style="{DynamicResource CardLabel}"/>
            <TextBlock Text="{Binding Snapshot.BatteryPct, StringFormat='{}{0}%', FallbackValue='—'}"
                       Style="{DynamicResource CardValue}"/>
            <TextBlock Text="{Binding Snapshot.BatteryStatus, FallbackValue=''}"
                       Style="{DynamicResource CardSub}"/>
            <TextBlock Text="{Binding Snapshot.BatteryHealth, FallbackValue=''}"
                       Style="{DynamicResource CardSub}"/>
          </StackPanel>
        </Border>

        <!-- Security -->
        <Border Style="{DynamicResource InfoCard}" Width="300">
          <StackPanel>
            <TextBlock Text="SECURITY" Style="{DynamicResource CardLabel}"/>
            <TextBlock Text="{Binding Snapshot.WindowsActivated, StringFormat='Windows activated: {0}', FallbackValue=''}"
                       Style="{DynamicResource CardSub}"/>
            <TextBlock Text="{Binding Snapshot.PendingUpdateCount, StringFormat='{}{0} pending update(s)', FallbackValue=''}"
                       Style="{DynamicResource CardSub}"/>
            <TextBlock Text="Defender: Active" Style="{DynamicResource CardSub}"
                       Foreground="{DynamicResource AccentGreenBrush}"
                       Visibility="{Binding Snapshot.DefenderEnabled, Converter={StaticResource BoolVis}}"/>
          </StackPanel>
        </Border>

      </WrapPanel>

      <Border Grid.Row="3" Style="{DynamicResource InfoCard}" Margin="0,20,0,0">
        <DockPanel>
          <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <TextBlock Text="Installed Programs" Style="{DynamicResource PageTitle}" FontSize="15"/>
            <TextBlock Text="{Binding InstalledProgramsSummaryText}" Style="{DynamicResource CardSub}"/>
          </StackPanel>

          <DockPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <Border DockPanel.Dock="Left" Style="{DynamicResource SearchBox}" Margin="0,0,8,0" Width="320">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <ui:SymbolIcon Grid.Column="0" Symbol="Search20" FontSize="14"
                               Foreground="{DynamicResource TextSecBrush}" Margin="0,0,8,0"
                               VerticalAlignment="Center"/>
                <TextBox Grid.Column="1" Text="{Binding InstalledProgramSearchText, UpdateSourceTrigger=PropertyChanged}"
                         BorderThickness="0" Background="Transparent" VerticalContentAlignment="Center"/>
              </Grid>
            </Border>
            <Button DockPanel.Dock="Right" Content="Apps &amp; Features" Click="OpenAppsSettings_Click"
                    Style="{DynamicResource SecondaryButton}"/>
          </DockPanel>

          <Grid>
            <Border Style="{DynamicResource FixCard}"
                    Visibility="{Binding InstalledProgramsLoading, Converter={StaticResource BoolVis}}">
              <StackPanel>
                <TextBlock Text="Loading installed programs..." Style="{DynamicResource CardSub}"/>
                <ProgressBar IsIndeterminate="True" Style="{DynamicResource IndeterminateBar}" Margin="0,8,0,0"/>
              </StackPanel>
            </Border>

            <Border Style="{DynamicResource FixCard}"
                    Visibility="{Binding ShowInstalledProgramsEmptyState, Converter={StaticResource BoolVis}}">
              <TextBlock Text="No app inventory loaded yet. Click 'Refresh Apps' to scan installed software."
                         Style="{DynamicResource CardSub}"/>
            </Border>

            <ScrollViewer MaxHeight="360" Visibility="{Binding HasInstalledPrograms, Converter={StaticResource BoolVis}}">
              <ItemsControl ItemsSource="{Binding InstalledPrograms}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate DataType="{x:Type m:InstalledProgram}">
                    <Border Style="{DynamicResource FixCard}" Padding="14,10">
                      <Grid>
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="*"/>
                          <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                          <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13"/>
                          <WrapPanel>
                            <TextBlock Text="{Binding Publisher}" Style="{DynamicResource CardSub}"
                                       Visibility="{Binding Publisher, Converter={StaticResource NullCollapsed}}"/>
                            <TextBlock Text="  •  " Style="{DynamicResource CardSub}"
                                       Visibility="{Binding Publisher, Converter={StaticResource NullCollapsed}}"/>
                            <TextBlock Text="{Binding Version}" Style="{DynamicResource CardSub}"
                                       Visibility="{Binding Version, Converter={StaticResource NullCollapsed}}"/>
                            <TextBlock Text="  •  " Style="{DynamicResource CardSub}"
                                       Visibility="{Binding SizeLabel, Converter={StaticResource NullCollapsed}}"/>
                            <TextBlock Text="{Binding SizeLabel}" Style="{DynamicResource CardSub}"
                                       Visibility="{Binding SizeLabel, Converter={StaticResource NullCollapsed}}"/>
                          </WrapPanel>
                          <TextBlock Text="{Binding InstallDateLabel}" Style="{DynamicResource CardSub}"
                                     Visibility="{Binding InstallDateLabel, Converter={StaticResource NullCollapsed}}"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="Uninstall" Tag="{Binding}" Click="RunUninstall_Click"
                                Style="{DynamicResource SecondaryButton}" Margin="12,0,0,0"
                                Visibility="{Binding UninstallCommand, Converter={StaticResource NullCollapsed}}"/>
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
          </Grid>
        </DockPanel>
      </Border>
    </Grid>
  </ScrollViewer>
</Page>
