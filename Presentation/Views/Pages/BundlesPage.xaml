<Page x:Class="HelpDesk.Presentation.Views.Pages.BundlesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:h="clr-namespace:HelpDesk.Presentation.Helpers"
      xmlns:m="clr-namespace:HelpDesk.Domain.Models"
      Background="{DynamicResource BgPrimaryBrush}">

  <Page.Resources>
    <h:BoolToVisConverter       x:Key="BoolVis"/>
    <h:InverseBoolToVisConverter x:Key="InvBoolVis"/>
    <h:NullToCollapsedConverter  x:Key="NullCollapsed"/>
  </Page.Resources>

  <ScrollViewer>
    <Grid Margin="28,24">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
      </Grid.RowDefinitions>

      <!-- Header -->
      <StackPanel Grid.Row="0" Margin="0,0,0,20">
        <TextBlock Text="Runbooks &amp; Fix Packs" Style="{DynamicResource PageTitle}"/>
        <TextBlock Text="Use guided multi-step support flows or run bundled maintenance packs." Style="{DynamicResource PageSubtitle}"/>
      </StackPanel>

      <!-- Bundle running progress -->
      <Border Grid.Row="1" Style="{DynamicResource InfoCard}"
              Visibility="{Binding IsBundleRunning, Converter={StaticResource BoolVis}}"
              Margin="0,0,0,16" BorderBrush="{DynamicResource FoxOrangeBrush}">
        <StackPanel>
          <TextBlock Text="{Binding RunningBundle.Title}" FontWeight="Bold" FontSize="14" Margin="0,0,0,4"/>
          <TextBlock Text="{Binding BundleStatus}" Style="{DynamicResource CardSub}" Margin="0,0,0,8"/>
          <ProgressBar Value="{Binding BundleProgress}" Maximum="{Binding BundleTotal}"
                       Height="8" Foreground="{DynamicResource FoxOrangeBrush}"
                       Background="{DynamicResource BorderBrush}" BorderThickness="0"/>
          <TextBlock Margin="0,4,0,0" FontSize="11" Foreground="{DynamicResource TextSecBrush}">
            <Run Text="{Binding BundleProgress, Mode=OneWay}"/>
            <Run Text=" of "/>
            <Run Text="{Binding BundleTotal, Mode=OneWay}"/>
            <Run Text=" fixes"/>
          </TextBlock>
        </StackPanel>
      </Border>

      <Border Grid.Row="2" Style="{DynamicResource InfoCard}" Margin="0,0,0,16">
        <DockPanel>
          <StackPanel DockPanel.Dock="Left">
            <TextBlock Text="Weekly Tune-Up Automation" Style="{DynamicResource PageTitle}" FontSize="15"/>
            <TextBlock Text="{Binding NextWeeklyTuneUpText, StringFormat='Next run: {0}'}"
                       Style="{DynamicResource CardSub}" Margin="0,4,0,12"/>
            <WrapPanel>
              <StackPanel Margin="0,0,12,8">
                <TextBlock Text="DAY" Style="{DynamicResource CardLabel}" Margin="0,0,0,4"/>
                <ComboBox ItemsSource="{Binding WeeklyTuneUpDayOptions}"
                          SelectedItem="{Binding SelectedWeeklyTuneUpDay, Mode=TwoWay}"
                          Width="150"/>
              </StackPanel>
              <StackPanel Margin="0,0,12,8">
                <TextBlock Text="TIME" Style="{DynamicResource CardLabel}" Margin="0,0,0,4"/>
                <ComboBox ItemsSource="{Binding WeeklyTuneUpTimeOptions}"
                          SelectedItem="{Binding SelectedWeeklyTuneUpTime, Mode=TwoWay}"
                          Width="120"/>
              </StackPanel>
            </WrapPanel>
          </StackPanel>
          <WrapPanel DockPanel.Dock="Right" HorizontalAlignment="Right" VerticalAlignment="Center">
            <Button Content="Save Schedule" Click="SaveWeeklyTuneUp_Click"
                    Style="{DynamicResource AccentButtonStyle}" Margin="0,0,8,8"/>
            <Button Content="Remove Schedule" Click="DisableWeeklyTuneUp_Click"
                    Style="{DynamicResource SecondaryButton}" Margin="0,0,8,8"/>
            <Button Content="Run Weekly Tune-Up Now" Click="RunWeeklyTuneUpNow_Click"
                    Style="{DynamicResource SecondaryButton}" Margin="0,0,0,8"/>
          </WrapPanel>
        </DockPanel>
      </Border>

      <!-- Runbooks and bundled packs -->
      <StackPanel Grid.Row="3">
      <TextBlock Text="GUIDED RUNBOOKS" Style="{DynamicResource CardLabel}" Margin="0,0,0,8"/>
      <ItemsControl ItemsSource="{Binding Runbooks}"
                    IsEnabled="{Binding IsBundleRunning, Converter={StaticResource InvBoolVis}}">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <WrapPanel/>
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
          <DataTemplate DataType="{x:Type m:RunbookDefinition}">
            <Border Style="{DynamicResource InfoCard}" Width="290" Margin="0,0,12,12">
              <DockPanel>
                <Button DockPanel.Dock="Bottom" Tag="{Binding}" Click="RunbookRun_Click"
                        Style="{DynamicResource SecondaryButton}" HorizontalAlignment="Stretch"
                        Margin="0,12,0,0" Cursor="Hand">
                  <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="Play20" FontSize="14" Margin="0,0,8,0"/>
                    <TextBlock Text="Run Runbook"/>
                  </StackPanel>
                </Button>
                <StackPanel>
                  <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="14"/>
                  <TextBlock Text="{Binding Description}" Style="{DynamicResource CardSub}"
                             TextWrapping="Wrap" Margin="0,6,0,10"/>
                  <WrapPanel>
                    <Border Background="{DynamicResource BgCard2Brush}" CornerRadius="4"
                            Padding="8,3" Margin="0,0,6,4">
                      <TextBlock FontSize="11" Foreground="{DynamicResource TextSecBrush}">
                        <Run Text="{Binding Steps.Count, Mode=OneWay}"/>
                        <Run Text=" steps"/>
                      </TextBlock>
                    </Border>
                    <Border Background="{DynamicResource BgCard2Brush}" CornerRadius="4"
                            Padding="8,3" Margin="0,0,0,4">
                      <TextBlock Text="{Binding MinimumEdition}" FontSize="11"
                                 Foreground="{DynamicResource TextSecBrush}"/>
                    </Border>
                  </WrapPanel>
                </StackPanel>
              </DockPanel>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

      <TextBlock Text="BUNDLED FIX PACKS" Style="{DynamicResource CardLabel}" Margin="0,12,0,8"/>
      <ItemsControl ItemsSource="{Binding Bundles}"
                    IsEnabled="{Binding IsBundleRunning, Converter={StaticResource InvBoolVis}}">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <WrapPanel/>
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
          <DataTemplate DataType="{x:Type m:FixBundle}">
            <Border Style="{DynamicResource InfoCard}" Width="290" Margin="0,0,12,12">
              <DockPanel>
                <Button DockPanel.Dock="Bottom" Tag="{Binding}" Click="BundleRun_Click"
                        Style="{DynamicResource AccentButtonStyle}" HorizontalAlignment="Stretch"
                        Margin="0,12,0,0" Cursor="Hand">
                  <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="Play20" FontSize="14" Margin="0,0,8,0"/>
                    <TextBlock Text="Run Fix Pack"/>
                  </StackPanel>
                </Button>
                <StackPanel>
                  <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                    <TextBlock Text="{Binding Icon}" FontFamily="{DynamicResource IconFont}"
                               FontSize="20" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
                  </StackPanel>
                  <TextBlock Text="{Binding Description}" Style="{DynamicResource CardSub}"
                             TextWrapping="Wrap" Margin="0,0,0,10"/>
                  <WrapPanel Margin="0,0,0,4">
                    <Border Background="{DynamicResource BgCard2Brush}" CornerRadius="4"
                            Padding="8,3" Margin="0,0,6,4">
                      <TextBlock FontSize="11" Foreground="{DynamicResource TextSecBrush}">
                        <Run Text="{Binding FixIds.Count, Mode=OneWay}"/>
                        <Run Text=" fixes"/>
                      </TextBlock>
                    </Border>
                    <Border Background="{DynamicResource BgCard2Brush}" CornerRadius="4"
                            Padding="8,3" Margin="0,0,0,4">
                      <TextBlock Text="{Binding EstTime}" FontSize="11"
                                 Foreground="{DynamicResource TextSecBrush}"/>
                    </Border>
                  </WrapPanel>
                </StackPanel>
              </DockPanel>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
      </StackPanel>
    </Grid>
  </ScrollViewer>
</Page>
