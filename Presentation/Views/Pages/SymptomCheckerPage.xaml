<Page x:Class="HelpDesk.Presentation.Views.Pages.SymptomCheckerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:h="clr-namespace:HelpDesk.Presentation.Helpers"
      xmlns:m="clr-namespace:HelpDesk.Domain.Models"
      Background="{DynamicResource BgPrimaryBrush}">

  <Page.Resources>
    <h:BoolToVisConverter x:Key="BoolVis"/>
    <h:InverseBoolToVisConverter x:Key="InvBoolVis"/>
    <h:NullToCollapsedConverter x:Key="NullCollapsed"/>
  </Page.Resources>

  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <Grid Margin="28,24">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
      </Grid.RowDefinitions>

      <StackPanel Grid.Row="0" Margin="0,0,0,20">
        <TextBlock Text="Guided Diagnosis" Style="{DynamicResource PageTitle}"/>
        <TextBlock Text="Describe what the user is seeing, what changed, and what already failed. FixFox will rank the most likely problem areas, suggest the safest first move, and surface the strongest matching fixes."
                   Style="{DynamicResource PageSubtitle}" TextWrapping="Wrap"/>
      </StackPanel>

      <Border Grid.Row="1" Style="{DynamicResource InfoCard}" Margin="0,0,0,18">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>

          <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,16,0">
              <TextBlock Text="Describe the issue" Style="{DynamicResource PanelTitle}"/>
              <TextBlock Text="Be specific: what is failing, when it happens, whether it affects one app or the whole PC, and what already changed."
                         Style="{DynamicResource CardSub}" Margin="0,6,0,0" TextWrapping="Wrap"/>
            </StackPanel>

            <WrapPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Top">
              <Button Content="Analyze" Click="SymptomSearch_Click"
                      Style="{DynamicResource AccentButtonStyle}" Margin="0,0,8,8" MinWidth="108"/>
              <Button Content="Clear" Click="ClearDiagnosis_Click"
                      Style="{DynamicResource SecondaryButton}" Margin="0,0,0,8" MinWidth="92"/>
            </WrapPanel>
          </Grid>

          <TextBox Grid.Row="1"
                   Text="{Binding SymptomInput, UpdateSourceTrigger=PropertyChanged}"
                   AcceptsReturn="True"
                   TextWrapping="Wrap"
                   VerticalScrollBarVisibility="Auto"
                   MinHeight="132"
                   Padding="14,12"
                   FontSize="14"
                   KeyDown="SymptomBox_KeyDown"/>

          <Grid Grid.Row="2" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="Examples: 'Wi-Fi shows connected but browsers time out', 'Teams opens but my mic is dead', 'PC is slow after startup and disk is nearly full'. Press Ctrl+Enter to analyze."
                       Style="{DynamicResource CardSub}" TextWrapping="Wrap" Margin="0,0,16,0"/>

            <WrapPanel Grid.Column="1">
              <Border Style="{DynamicResource StatPill}">
                <StackPanel>
                  <TextBlock Text="LIKELY AREAS" Style="{DynamicResource CardLabel}"/>
                  <TextBlock Text="{Binding TriageCandidates.Count}" Style="{DynamicResource CardValue}"/>
                </StackPanel>
              </Border>
              <Border Style="{DynamicResource StatPill}">
                <StackPanel>
                  <TextBlock Text="MATCHING FIXES" Style="{DynamicResource CardLabel}"/>
                  <TextBlock Text="{Binding SymptomCount}" Style="{DynamicResource CardValue}"/>
                </StackPanel>
              </Border>
            </WrapPanel>
          </Grid>
        </Grid>
      </Border>

      <Grid Grid.Row="2">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="380"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Margin="0,0,18,0">
          <StackPanel Margin="0,0,0,14"
                      Visibility="{Binding RecentSearches.Count, Converter={StaticResource NullCollapsed}}">
            <TextBlock Text="Recent diagnosis prompts" Style="{DynamicResource PanelTitle}" Margin="0,0,0,8"/>
            <ItemsControl ItemsSource="{Binding RecentSearches}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <WrapPanel/>
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Button Content="{Binding}" Tag="{Binding}" Click="RecentSearch_Click"
                          Style="{DynamicResource SecondaryButton}" Margin="0,0,8,8"/>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>

          <Border Style="{DynamicResource InfoCard}"
                  Visibility="{Binding HasTriageCandidates, Converter={StaticResource BoolVis}}">
            <StackPanel>
              <TextBlock Text="What FixFox thinks is happening" Style="{DynamicResource PanelTitle}"/>
              <TextBlock Text="These ranked issue areas explain why FixFox is steering you toward certain fixes instead of blindly running the whole catalog."
                         Style="{DynamicResource CardSub}" Margin="0,6,0,14" TextWrapping="Wrap"/>

              <ItemsControl ItemsSource="{Binding TriageCandidates}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate DataType="{x:Type m:TriageCandidate}">
                    <Border Style="{DynamicResource FixCard}" Padding="14" Margin="0,0,0,10">
                      <StackPanel>
                        <DockPanel Margin="0,0,0,8">
                          <StackPanel DockPanel.Dock="Left">
                            <TextBlock Text="{Binding CategoryName}" Style="{DynamicResource PanelTitle}"/>
                            <TextBlock Text="{Binding ProbableSubIssue}" Style="{DynamicResource MetaText}"
                                       Visibility="{Binding ProbableSubIssue, Converter={StaticResource NullCollapsed}}"/>
                          </StackPanel>
                          <Border DockPanel.Dock="Right" Background="{DynamicResource BgCard2Brush}" CornerRadius="12" Padding="10,4" Margin="12,0,0,0">
                            <TextBlock Text="{Binding ConfidenceLabel}" Style="{DynamicResource MetaText}"/>
                          </Border>
                        </DockPanel>

                        <TextBlock Text="{Binding WhatIThinkIsWrong}" FontWeight="SemiBold" FontSize="13" TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding WhyIThinkThat}" Style="{DynamicResource CardSub}" Margin="0,6,0,0" TextWrapping="Wrap"/>

                        <Grid Margin="0,12,0,0">
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                          </Grid.ColumnDefinitions>

                          <Border Grid.Column="0" Background="{DynamicResource BgCard2Brush}" CornerRadius="8" Padding="12,10" Margin="0,0,8,0">
                            <StackPanel>
                              <TextBlock Text="Safest first action" Style="{DynamicResource CardLabel}"/>
                              <TextBlock Text="{Binding SafestFirstAction}" Style="{DynamicResource CardSub}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                          </Border>

                          <Border Grid.Column="1" Background="{DynamicResource BgCard2Brush}" CornerRadius="8" Padding="12,10" Margin="8,0,0,0">
                            <StackPanel>
                              <TextBlock Text="Stronger next action" Style="{DynamicResource CardLabel}"/>
                              <TextBlock Text="{Binding StrongerNextAction}" Style="{DynamicResource CardSub}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                          </Border>
                        </Grid>

                        <Border Background="{DynamicResource BgCard2Brush}" CornerRadius="8" Padding="12,10" Margin="0,10,0,0"
                                Visibility="{Binding EscalationSignal, Converter={StaticResource NullCollapsed}}">
                          <StackPanel>
                            <TextBlock Text="Escalate when" Style="{DynamicResource CardLabel}"/>
                            <TextBlock Text="{Binding EscalationSignal}" Style="{DynamicResource CardSub}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                          </StackPanel>
                        </Border>

                        <Border Background="{DynamicResource BgCard2Brush}" CornerRadius="8" Padding="12,10" Margin="0,10,0,0"
                                Visibility="{Binding DataContext.AdvancedModeEnabled, RelativeSource={RelativeSource AncestorType=Page}, Converter={StaticResource BoolVis}}">
                          <StackPanel>
                            <TextBlock Text="Advanced detail" Style="{DynamicResource CardLabel}"/>
                            <TextBlock Text="{Binding AdvancedDetails}" Style="{DynamicResource CardSub}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                          </StackPanel>
                        </Border>

                        <TextBlock Text="{Binding WhatWillHappen}" Style="{DynamicResource CardSub}" Margin="0,10,0,0" TextWrapping="Wrap"/>
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </Border>

          <Border Style="{DynamicResource InfoCard}"
                  Visibility="{Binding SymptomSearched, Converter={StaticResource InvBoolVis}}">
            <StackPanel>
              <TextBlock Text="Start with a real symptom description" Style="{DynamicResource PanelTitle}"/>
              <TextBlock Text="This page works best when you describe the behavior, not the fix you already want to try. Good prompts mention whether the problem is device-wide or app-specific, whether it started after an update, and whether rebooting helped."
                         Style="{DynamicResource CardSub}" Margin="0,6,0,0" TextWrapping="Wrap"/>
            </StackPanel>
          </Border>
        </StackPanel>

        <StackPanel Grid.Column="1">
          <Border Style="{DynamicResource InfoCard}" Margin="0,0,0,12">
            <StackPanel>
              <TextBlock Text="Recommended repair actions" Style="{DynamicResource PanelTitle}"/>
              <TextBlock Text="These are the strongest matching fixes from the diagnosis result. Guided repairs stay interactive. Scripted repairs run directly and verify afterward."
                         Style="{DynamicResource CardSub}" Margin="0,6,0,12" TextWrapping="Wrap"/>

              <ItemsControl ItemsSource="{Binding SymptomResults}"
                            Visibility="{Binding SymptomCount, Converter={StaticResource NullCollapsed}}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate DataType="{x:Type m:FixItem}">
                    <Border Style="{DynamicResource FixCard}" Padding="14" Margin="0,0,0,10"
                            Tag="{Binding}"
                            MouseLeftButtonDown="ResultCard_MouseLeftButtonDown">
                      <Border.ContextMenu>
                        <ContextMenu DataContext="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource Self}}">
                          <MenuItem Header="Run Best Action" Click="RunBestAction_Click" CommandParameter="{Binding}"/>
                          <MenuItem Header="Start Guided Repair" Click="GuidedMenu_Click" CommandParameter="{Binding}"/>
                          <MenuItem Header="Run Repair" Click="RunMenu_Click" CommandParameter="{Binding}"/>
                          <Separator/>
                          <MenuItem Header="View Details" Click="FixDetails_Click" CommandParameter="{Binding}"/>
                          <MenuItem Header="Copy Technical Detail" Click="CopyFixDetails_Click" CommandParameter="{Binding}"/>
                          <MenuItem Header="Open Related Workflow" Click="OpenRelatedWorkflow_Click" CommandParameter="{Binding}"/>
                          <Separator/>
                          <MenuItem Header="Copy Repair Name" Click="CopyFixTitle_Click" CommandParameter="{Binding}"/>
                        </ContextMenu>
                      </Border.ContextMenu>
                      <DockPanel LastChildFill="True">
                        <WrapPanel DockPanel.Dock="Right" VerticalAlignment="Top" Margin="12,0,0,0">
                          <Button Content="Guide" Tag="{Binding}" Click="GuidedButton_Click"
                                  Style="{DynamicResource SecondaryButton}"
                                  Visibility="{Binding HasSteps, Converter={StaticResource BoolVis}}"
                                  Margin="0,0,8,8"/>
                          <Button Content="Run" Tag="{Binding}" Click="FixButton_Click"
                                  Style="{DynamicResource PrimaryButton}"
                                  Visibility="{Binding HasScript, Converter={StaticResource BoolVis}}"
                                  Margin="0,0,0,8"/>
                          <Button Content="Details" Tag="{Binding}" Click="FixDetailsButton_Click"
                                  Style="{DynamicResource SecondaryButton}"
                                  Margin="0,0,0,8"/>
                        </WrapPanel>

                          <StackPanel>
                            <WrapPanel Margin="0,0,0,4">
                              <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="13"/>
                              <Border Background="{DynamicResource BgCard2Brush}" CornerRadius="4" Padding="6,2" Margin="8,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Type}" FontSize="10" Foreground="{DynamicResource TextSecBrush}"/>
                              </Border>
                              <Border Style="{DynamicResource CompactStatusBadge}"
                                      Margin="8,0,0,0"
                                      VerticalAlignment="Center"
                                      Visibility="{Binding HasStatusIndicator, Converter={StaticResource BoolVis}}">
                                <StackPanel Orientation="Horizontal">
                                  <Ellipse Style="{DynamicResource CompactStatusDot}" VerticalAlignment="Center"/>
                                  <TextBlock Text="{Binding StatusSummary}" Style="{DynamicResource CompactStatusText}" Margin="6,0,0,0"/>
                                </StackPanel>
                              </Border>
                            </WrapPanel>
                            <TextBlock Text="{Binding Description}" Style="{DynamicResource CardSub}" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding LastOutput}" Style="{DynamicResource MetaText}" Margin="0,8,0,0"
                                       TextWrapping="Wrap"
                                       Visibility="{Binding LastOutput, Converter={StaticResource NullCollapsed}}"/>
                            <ProgressBar Style="{DynamicResource IndeterminateBar}"
                                         Margin="0,8,0,0"
                                         Visibility="{Binding IsRunning, Converter={StaticResource BoolVis}}"/>
                          </StackPanel>
                      </DockPanel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>

              <TextBlock Text="Analyze an issue to see matched fixes here."
                         Style="{DynamicResource CardSub}"
                         Visibility="{Binding SymptomSearched, Converter={StaticResource InvBoolVis}}"/>
              <TextBlock Text="No strong repair match yet. Try describing the symptom more broadly, such as internet, audio, startup, update, printer, camera, or crash."
                         Style="{DynamicResource CardSub}"
                         Visibility="{Binding SymptomHasNoResults, Converter={StaticResource BoolVis}}"/>
            </StackPanel>
          </Border>

          <Border Style="{DynamicResource InfoCard}">
            <StackPanel>
              <TextBlock Text="How to write a better diagnosis prompt" Style="{DynamicResource PanelTitle}"/>
              <TextBlock Text="Include what fails, when it fails, and what still works." Style="{DynamicResource CardSub}" Margin="0,8,0,0"/>
              <TextBlock Text="Say whether the problem affects one app, one device, or the whole workstation." Style="{DynamicResource CardSub}" Margin="0,6,0,0"/>
              <TextBlock Text="Mention recent changes like Windows updates, dock changes, VPN sign-in issues, or new hardware." Style="{DynamicResource CardSub}" Margin="0,6,0,0"/>
              <TextBlock Text="If the issue looks like account, certificate, policy, or permissions trouble, use Support Package after diagnosis instead of forcing local repairs." Style="{DynamicResource CardSub}" Margin="0,6,0,0"/>
            </StackPanel>
          </Border>
        </StackPanel>
      </Grid>
    </Grid>
  </ScrollViewer>
</Page>
