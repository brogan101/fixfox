<Page x:Class="HelpDesk.Presentation.Views.Pages.SymptomCheckerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:h="clr-namespace:HelpDesk.Presentation.Helpers"
      xmlns:m="clr-namespace:HelpDesk.Domain.Models"
      Background="{DynamicResource BgPrimaryBrush}">

  <Page.Resources>
    <h:BoolToVisConverter        x:Key="BoolVis"/>
    <h:InverseBoolToVisConverter x:Key="InvBoolVis"/>
    <h:NullToCollapsedConverter  x:Key="NullCollapsed"/>
  </Page.Resources>

  <Grid Margin="28,24">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <!-- Header -->
    <StackPanel Grid.Row="0" Margin="0,0,0,20">
      <TextBlock Text="Fix An Issue" Style="{DynamicResource PageTitle}"/>
      <TextBlock Text="Describe the problem in plain English and FixFox will rank the most likely issue paths." Style="{DynamicResource PageSubtitle}"/>
    </StackPanel>

    <!-- Search bar -->
    <Grid Grid.Row="1" Margin="0,0,0,20">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>
      <Border Grid.Column="0" Style="{DynamicResource SearchBox}" Margin="0,0,8,0">
        <TextBox Text="{Binding SymptomInput, UpdateSourceTrigger=PropertyChanged}"
                 BorderThickness="0" Background="Transparent"
                 FontSize="14" VerticalContentAlignment="Center"
                 KeyDown="SymptomBox_KeyDown">
          <TextBox.Style>
            <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
              <Setter Property="Template">
                <Setter.Value>
                  <ControlTemplate TargetType="TextBox">
                    <Grid>
                      <TextBlock Text="e.g. Wi-Fi says connected but nothing loads, Outlook freezes, printer queue is stuck..."
                                 Foreground="{DynamicResource TextMutedBrush}"
                                 FontSize="14" VerticalAlignment="Center"
                                 Visibility="{Binding Text, RelativeSource={RelativeSource TemplatedParent},
                                              Converter={StaticResource NullCollapsed}}"/>
                      <ScrollViewer x:Name="PART_ContentHost"/>
                    </Grid>
                  </ControlTemplate>
                </Setter.Value>
              </Setter>
            </Style>
          </TextBox.Style>
        </TextBox>
      </Border>
      <Button Grid.Column="1" Content="Search" Click="SymptomSearch_Click"
              Style="{DynamicResource AccentButtonStyle}" Width="100"/>
    </Grid>

    <StackPanel Grid.Row="2" Margin="0,0,0,16"
                Visibility="{Binding RecentSearches.Count, Converter={StaticResource NullCollapsed}}">
      <TextBlock Text="RECENT SEARCHES" Style="{DynamicResource CardLabel}" Margin="0,0,0,6"/>
      <ItemsControl ItemsSource="{Binding RecentSearches}">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Button Content="{Binding}" Tag="{Binding}" Click="RecentSearch_Click"
                    Style="{DynamicResource SecondaryButton}" Margin="0,0,8,8"/>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </StackPanel>

    <!-- Results -->
    <StackPanel Grid.Row="3">
      <ItemsControl ItemsSource="{Binding TriageCandidates}"
                    Visibility="{Binding HasTriageCandidates, Converter={StaticResource BoolVis}}"
                    Margin="0,0,0,14">
        <ItemsControl.ItemTemplate>
          <DataTemplate DataType="{x:Type m:TriageCandidate}">
            <Border Style="{DynamicResource InfoCard}" Margin="0,0,0,10">
              <StackPanel>
                <DockPanel Margin="0,0,0,8">
                  <TextBlock Text="{Binding CategoryName}" FontWeight="Bold" FontSize="15"/>
                  <Border DockPanel.Dock="Right" Background="{DynamicResource BgCard2Brush}" CornerRadius="10" Padding="10,4">
                    <TextBlock Text="{Binding ConfidenceLabel}" FontSize="11"/>
                  </Border>
                </DockPanel>
                <TextBlock FontSize="12" Foreground="{DynamicResource TextSecBrush}">
                  <Run Text="Probable sub-issue: "/>
                  <Run Text="{Binding ProbableSubIssue}"/>
                  <Run Text="  |  Confidence: "/>
                  <Run Text="{Binding ConfidenceScore}"/>
                  <Run Text="%"/>
                </TextBlock>
                <TextBlock Text="{Binding WhatIThinkIsWrong}" FontWeight="SemiBold" Margin="0,8,0,2"/>
                <TextBlock Text="{Binding WhyIThinkThat}" Style="{DynamicResource CardSub}" TextWrapping="Wrap"/>
                <TextBlock Text="{Binding WhatWillHappen}" Style="{DynamicResource CardSub}" TextWrapping="Wrap" Margin="0,8,0,0"/>
              </StackPanel>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

      <TextBlock Visibility="{Binding SymptomSearched, Converter={StaticResource BoolVis}}"
                 Margin="0,0,0,10" Foreground="{DynamicResource TextSecBrush}" FontSize="12">
        <Run Text="{Binding SymptomCount, Mode=OneWay}"/>
        <Run Text=" recommended repair options"/>
      </TextBlock>

      <ScrollViewer>
        <ItemsControl ItemsSource="{Binding SymptomResults}"
                      VirtualizingStackPanel.IsVirtualizing="True">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate><VirtualizingStackPanel/></ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate DataType="{x:Type m:FixItem}">
              <Border Style="{DynamicResource FixCard}">
                <DockPanel>
                  <Button DockPanel.Dock="Right" Content="Run" Tag="{Binding}"
                          Click="FixButton_Click" Style="{DynamicResource PrimaryButton}"
                          VerticalAlignment="Center"
                          Visibility="{Binding HasScript, Converter={StaticResource BoolVis}}"
                          Cursor="Hand"/>
                  <StackPanel>
                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="13"/>
                    <TextBlock Text="{Binding Description}" Style="{DynamicResource CardSub}"
                               TextWrapping="Wrap"/>
                  </StackPanel>
                </DockPanel>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>

      <TextBlock Text="Describe your issue above and press Search."
                 Style="{DynamicResource CardSub}" HorizontalAlignment="Center"
                 Margin="0,40,0,0" FontSize="14"
                 Visibility="{Binding SymptomSearched, Converter={StaticResource InvBoolVis}}"/>
      <TextBlock Text="No matching fixes yet. Try broader words like 'internet', 'audio', 'startup', or 'crash'."
                 Style="{DynamicResource CardSub}" HorizontalAlignment="Center"
                 Margin="0,20,0,0" FontSize="14"
                 Visibility="{Binding SymptomHasNoResults, Converter={StaticResource BoolVis}}"/>
    </StackPanel>
  </Grid>
</Page>
