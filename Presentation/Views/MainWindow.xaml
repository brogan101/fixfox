<ui:FluentWindow x:Class="HelpDesk.Presentation.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:h="clr-namespace:HelpDesk.Presentation.Helpers"
        Title="{Binding ProductDisplayName}"
        MinWidth="960" MinHeight="620"
        Width="{Binding Settings.WindowWidth,  Mode=TwoWay}"
        Height="{Binding Settings.WindowHeight, Mode=TwoWay}"
        WindowStartupLocation="CenterScreen"
        ExtendsContentIntoTitleBar="True"
        Closing="Window_Closing"
        KeyDown="Window_KeyDown">

  <ui:FluentWindow.Resources>
    <h:NullToCollapsedConverter    x:Key="NullCollapsed"/>
    <h:NullOrWhiteSpaceToVisibleConverter x:Key="NullOrWhiteSpaceVisible"/>
    <h:InverseBoolConverter        x:Key="InvBool"/>
    <h:BoolToVisConverter          x:Key="BoolVis"/>
    <h:InverseBoolToVisConverter   x:Key="InvBoolVis"/>
    <h:PercentColorConverter       x:Key="PctColor"/>
    <h:SeverityColorConverter      x:Key="SevColor"/>
    <h:NotifLevelColorConverter    x:Key="NotifColor"/>
    <h:StatusBgConverter           x:Key="StatusBg"/>
    <h:StatusFgConverter           x:Key="StatusFg"/>
    <h:RunningVisConverter         x:Key="RunningVis"/>
    <h:StatusIconConverter         x:Key="StatusIcon"/>
    <h:FavoriteIconConverter       x:Key="FavIcon"/>
    <h:PinIconConverter            x:Key="PinIcon"/>
    <h:RelativeDateConverter       x:Key="RelDate"/>
    <h:ThemeIsDarkConverter        x:Key="ThemeIsDark"/>
    <h:AdminShieldVisConverter     x:Key="AdminVis"/>
    <h:SidebarWidthConverter       x:Key="SidebarWidth"/>
    <h:SidebarAlignConverter       x:Key="SidebarAlign"/>
    <h:SidebarPaddingConverter     x:Key="SidebarPad"/>
  </ui:FluentWindow.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="48"/>  <!-- Custom title bar -->
      <RowDefinition Height="Auto"/><!-- BreadcrumbBar -->
      <RowDefinition Height="*"/>   <!-- Content -->
      <RowDefinition Height="28"/>  <!-- Status bar -->
    </Grid.RowDefinitions>

    <!-- ════════════════════ TITLE BAR ════════════════════ -->
    <Grid Grid.Row="0" Background="{DynamicResource TitleBarBrush}"
          MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>

      <!-- Logo + name -->
      <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
        <Image x:Name="LogoImage" Width="32" Height="32" Margin="0,0,8,0"
               RenderOptions.BitmapScalingMode="HighQuality" VerticalAlignment="Center"/>
        <TextBlock Text="{Binding ProductDisplayName}" FontSize="14" FontWeight="Bold"
                   Foreground="{DynamicResource FoxOrangeBrush}" VerticalAlignment="Center"/>
      </StackPanel>

      <!-- Center drag area with lightweight context -->
      <Grid Grid.Column="1">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="16,0,0,0">
          <WrapPanel>
            <TextBlock Text="{Binding CurrentPageLabel}" FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
            <TextBlock Text="  •  " FontSize="11" Foreground="{DynamicResource TextSecBrush}" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding CurrentPageSummaryText}" FontSize="11"
                       Foreground="{DynamicResource TextSecBrush}" VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis"/>
          </WrapPanel>
        </StackPanel>
        <Border Grid.Column="1"
                Background="{DynamicResource BgCard2Brush}"
                CornerRadius="10"
                Padding="10,4"
                Margin="12,0,0,0"
                VerticalAlignment="Center">
          <TextBlock Text="{Binding CurrentProfileStatusText}" Style="{DynamicResource MetaText}"/>
        </Border>
      </Grid>

      <!-- Min / Max / Close buttons -->
      <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Stretch">
        <Button x:Name="NotificationsToggle"
                Style="{DynamicResource TitleBarButtonStyle}"
                Click="NotificationsToggle_Click">
          <Grid Width="30" Height="28">
            <ui:SymbolIcon Symbol="Alert20" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,1,0,0"/>
            <Border HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    MinWidth="14"
                    Height="14"
                    Margin="0,2,2,0"
                    Padding="3,0"
                    Background="{DynamicResource AccentRedBrush}"
                    CornerRadius="7"
                    Visibility="{Binding UnreadNotifCount, Converter={StaticResource NullCollapsed}}">
              <TextBlock Text="{Binding UnreadNotifCount}"
                         FontSize="9"
                         FontWeight="Bold"
                         Foreground="White"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"
                         TextAlignment="Center"/>
            </Border>
          </Grid>
        </Button>
        <Button Style="{DynamicResource TitleBarButtonStyle}" Click="WinMin_Click">
          <ui:SymbolIcon Symbol="Subtract16" FontSize="9"/>
        </Button>
        <Button x:Name="BtnMaxRestore" Style="{DynamicResource TitleBarButtonStyle}"
                Click="WinMaxRestore_Click">
          <ui:SymbolIcon x:Name="MaxRestoreIcon" Symbol="Maximize16" FontSize="9"/>
        </Button>
        <Button Style="{DynamicResource TitleBarCloseButtonStyle}" Click="WinClose_Click">
          <ui:SymbolIcon Symbol="Dismiss16" FontSize="9"/>
        </Button>
      </StackPanel>
    </Grid>

    <!-- ════════════════════ BREADCRUMB ════════════════════ -->
    <Border Grid.Row="1" Background="{DynamicResource BgSurfaceBrush}"
            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
            Padding="16,4">
      <ui:BreadcrumbBar x:Name="BreadcrumbCtrl" ItemsSource="{Binding BreadcrumbItems}"
                        FontSize="12" Foreground="{DynamicResource TextSecBrush}">
        <ui:BreadcrumbBar.ItemTemplate>
          <DataTemplate>
            <TextBlock Text="{Binding}"/>
          </DataTemplate>
        </ui:BreadcrumbBar.ItemTemplate>
      </ui:BreadcrumbBar>
    </Border>

    <!-- ════════════════════ MAIN AREA (sidebar + content) ════════════════════ -->
    <Grid Grid.Row="2">
      <Grid.ColumnDefinitions>
        <ColumnDefinition x:Name="SidebarColumn"
                          Width="{Binding IsSidebarCollapsed, Converter={StaticResource SidebarWidth}}"
                          MinWidth="48"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <!-- ══ SIDEBAR ══ -->
      <Border Grid.Column="0" Background="{DynamicResource BgSurfaceBrush}"
              BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0">
        <DockPanel ClipToBounds="True">

          <!-- Footer -->
          <Border DockPanel.Dock="Bottom" Padding="0,8,0,10"
                  Visibility="{Binding IsSidebarCollapsed, Converter={StaticResource InvBoolVis}}">
            <StackPanel HorizontalAlignment="Center">
              <TextBlock Text="{Binding ProductDisplayName}" FontSize="10"
                         Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center" Margin="0,2,0,0"/>
              <TextBlock Text="{Binding ProductSubtitle}" FontSize="10"
                         Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center"
                         Visibility="{Binding IsSidebarCollapsed, Converter={StaticResource InvBoolVis}}"/>
            </StackPanel>
          </Border>

          <!-- Collapse toggle button at bottom of nav -->
          <Button DockPanel.Dock="Bottom" Click="SidebarToggle_Click"
                  Style="{DynamicResource NavButtonStyle}"
                  ToolTip="Collapse/Expand sidebar" ToolTipService.InitialShowDelay="400"
                  Padding="{Binding IsSidebarCollapsed, Converter={StaticResource SidebarPad}}"
                  HorizontalContentAlignment="{Binding IsSidebarCollapsed, Converter={StaticResource SidebarAlign}}">
            <StackPanel Orientation="Horizontal">
              <ui:SymbolIcon Symbol="PanelLeftContract20" FontSize="16" Width="18"
                             VerticalAlignment="Center" HorizontalAlignment="Center"/>
              <TextBlock Text="Collapse panel" Margin="10,0,0,0" VerticalAlignment="Center" FontSize="12"
                         Visibility="{Binding IsSidebarCollapsed, Converter={StaticResource InvBoolVis}}"/>
            </StackPanel>
          </Button>

          <!-- Categories list (shown on Fix Center page) -->
          <ScrollViewer DockPanel.Dock="Bottom"
                        Visibility="{Binding ShowFixes, Converter={StaticResource BoolVis}}"
                        MaxHeight="260" VerticalScrollBarVisibility="Auto">
            <StackPanel>
              <TextBlock Text="REPAIR CATEGORIES" Style="{DynamicResource SectionLabelStyle}"
                         Visibility="{Binding IsSidebarCollapsed, Converter={StaticResource InvBoolVis}}"/>
              <ItemsControl ItemsSource="{Binding Categories}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Button Tag="{Binding}" Click="Category_Click"
                            Style="{DynamicResource NavButtonStyle}"
                            Padding="{Binding DataContext.IsSidebarCollapsed,
                                     RelativeSource={RelativeSource AncestorType=Window},
                                     Converter={StaticResource SidebarPad}}"
                            HorizontalContentAlignment="{Binding DataContext.IsSidebarCollapsed,
                                     RelativeSource={RelativeSource AncestorType=Window},
                                     Converter={StaticResource SidebarAlign}}"
                            ToolTip="{Binding Title}" ToolTipService.InitialShowDelay="400"
                            Cursor="Hand">
                      <StackPanel Orientation="Horizontal">
                        <TextBlock FontFamily="{DynamicResource IconFont}" Text="{Binding Icon}"
                                   FontSize="14" Width="18" TextAlignment="Center" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding Title}" FontSize="12" VerticalAlignment="Center"
                                   Margin="8,0,0,0"
                                   Visibility="{Binding DataContext.IsSidebarCollapsed,
                                                RelativeSource={RelativeSource AncestorType=Window},
                                                Converter={StaticResource InvBoolVis}}"/>
                      </StackPanel>
                    </Button>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </ScrollViewer>

          <!-- Navigation -->
          <ScrollViewer DockPanel.Dock="Top" VerticalScrollBarVisibility="Disabled">
            <StackPanel>

              <!-- WORKSPACE -->
              <TextBlock Text="WORKSPACE" Style="{DynamicResource SectionLabelStyle}"
                         Visibility="{Binding IsSidebarCollapsed, Converter={StaticResource InvBoolVis}}"/>

              <Button x:Name="NavDashboard" Tag="Dashboard" Click="Nav_Click"
                      Style="{DynamicResource NavButtonStyle}"
                      Padding="{Binding IsSidebarCollapsed, Converter={StaticResource SidebarPad}}"
                      HorizontalContentAlignment="{Binding IsSidebarCollapsed, Converter={StaticResource SidebarAlign}}"
                      ToolTip="Home  Ctrl+1" ToolTipService.InitialShowDelay="400" Cursor="Hand">
                <StackPanel Orientation="Horizontal">
                  <ui:SymbolIcon Symbol="Home20" FontSize="16" Width="18" VerticalAlignment="Center"/>
                  <TextBlock Text="Home" Margin="10,0,0,0" VerticalAlignment="Center" FontSize="12"
                             Visibility="{Binding IsSidebarCollapsed, Converter={StaticResource InvBoolVis}}"/>
                </StackPanel>
              </Button>

              <Button x:Name="NavSymptomChecker" Tag="SymptomChecker" Click="Nav_Click"
                      Style="{DynamicResource NavButtonStyle}"
                      Padding="{Binding IsSidebarCollapsed, Converter={StaticResource SidebarPad}}"
                      HorizontalContentAlignment="{Binding IsSidebarCollapsed, Converter={StaticResource SidebarAlign}}"
                      ToolTip="Guided Diagnosis  Ctrl+2" ToolTipService.InitialShowDelay="400" Cursor="Hand">
                <StackPanel Orientation="Horizontal">
                  <ui:SymbolIcon Symbol="QuestionCircle20" FontSize="16" Width="18" VerticalAlignment="Center"/>
                  <TextBlock Text="Guided Diagnosis" Margin="10,0,0,0" VerticalAlignment="Center" FontSize="12"
                             Visibility="{Binding IsSidebarCollapsed, Converter={StaticResource InvBoolVis}}"/>
                </StackPanel>
              </Button>

              <Button x:Name="NavFixes" Tag="Fixes" Click="Nav_Click"
                      Style="{DynamicResource NavButtonStyle}"
                      Padding="{Binding IsSidebarCollapsed, Converter={StaticResource SidebarPad}}"
                      HorizontalContentAlignment="{Binding IsSidebarCollapsed, Converter={StaticResource SidebarAlign}}"
                      ToolTip="Repair Library  Ctrl+3" ToolTipService.InitialShowDelay="400" Cursor="Hand">
                <StackPanel Orientation="Horizontal">
                  <ui:SymbolIcon Symbol="Wrench20" FontSize="16" Width="18" VerticalAlignment="Center"/>
                  <TextBlock Text="Repair Library" Margin="10,0,0,0" VerticalAlignment="Center" FontSize="12"
                             Visibility="{Binding IsSidebarCollapsed, Converter={StaticResource InvBoolVis}}"/>
                </StackPanel>
              </Button>

              <Button x:Name="NavBundles" Tag="Bundles" Click="Nav_Click"
                      Style="{DynamicResource NavButtonStyle}"
                      Padding="{Binding IsSidebarCollapsed, Converter={StaticResource SidebarPad}}"
                      HorizontalContentAlignment="{Binding IsSidebarCollapsed, Converter={StaticResource SidebarAlign}}"
                      ToolTip="Automation  Ctrl+4" ToolTipService.InitialShowDelay="400" Cursor="Hand">
                <StackPanel Orientation="Horizontal">
                  <ui:SymbolIcon Symbol="LayerDiagonal20" FontSize="16" Width="18" VerticalAlignment="Center"/>
                  <TextBlock Text="Automation" Margin="10,0,0,0" VerticalAlignment="Center" FontSize="12"
                             Visibility="{Binding IsSidebarCollapsed, Converter={StaticResource InvBoolVis}}"/>
                </StackPanel>
              </Button>

              <Separator Margin="12,4"/>

              <!-- SUPPORT -->
              <TextBlock Text="SUPPORT" Style="{DynamicResource SectionLabelStyle}"
                         Visibility="{Binding IsSidebarCollapsed, Converter={StaticResource InvBoolVis}}"/>

              <Button x:Name="NavSystemInfo" Tag="SystemInfo" Click="Nav_Click"
                      Style="{DynamicResource NavButtonStyle}"
                      Padding="{Binding IsSidebarCollapsed, Converter={StaticResource SidebarPad}}"
                      HorizontalContentAlignment="{Binding IsSidebarCollapsed, Converter={StaticResource SidebarAlign}}"
                      ToolTip="Device Health  Ctrl+5" ToolTipService.InitialShowDelay="400" Cursor="Hand">
                <StackPanel Orientation="Horizontal">
                  <ui:SymbolIcon Symbol="DesktopPulse20" FontSize="16" Width="18" VerticalAlignment="Center"/>
                  <TextBlock Text="Device Health" Margin="10,0,0,0" VerticalAlignment="Center" FontSize="12"
                             Visibility="{Binding IsSidebarCollapsed, Converter={StaticResource InvBoolVis}}"/>
                </StackPanel>
              </Button>

              <Button x:Name="NavToolbox" Tag="Toolbox" Click="Nav_Click"
                      Style="{DynamicResource NavButtonStyle}"
                      Padding="{Binding IsSidebarCollapsed, Converter={StaticResource SidebarPad}}"
                      HorizontalContentAlignment="{Binding IsSidebarCollapsed, Converter={StaticResource SidebarAlign}}"
                      ToolTip="Windows Tools  Ctrl+8" ToolTipService.InitialShowDelay="400" Cursor="Hand">
                <StackPanel Orientation="Horizontal">
                  <ui:SymbolIcon Symbol="Toolbox20" FontSize="16" Width="18" VerticalAlignment="Center"/>
                  <TextBlock Text="Windows Tools" Margin="10,0,0,0" VerticalAlignment="Center" FontSize="12"
                             Visibility="{Binding IsSidebarCollapsed, Converter={StaticResource InvBoolVis}}"/>
                </StackPanel>
              </Button>

              <Button x:Name="NavHandoff" Tag="Handoff" Click="Nav_Click"
                      Style="{DynamicResource NavButtonStyle}"
                      Padding="{Binding IsSidebarCollapsed, Converter={StaticResource SidebarPad}}"
                      HorizontalContentAlignment="{Binding IsSidebarCollapsed, Converter={StaticResource SidebarAlign}}"
                      ToolTip="Support Package  Ctrl+6" ToolTipService.InitialShowDelay="400" Cursor="Hand">
                <StackPanel Orientation="Horizontal">
                  <ui:SymbolIcon Symbol="DocumentBulletList20" FontSize="16" Width="18" VerticalAlignment="Center"/>
                  <TextBlock Text="Support Package" Margin="10,0,0,0" VerticalAlignment="Center" FontSize="12"
                             Visibility="{Binding IsSidebarCollapsed, Converter={StaticResource InvBoolVis}}"/>
                </StackPanel>
              </Button>

              <Button x:Name="NavHistory" Tag="History" Click="Nav_Click"
                      Style="{DynamicResource NavButtonStyle}"
                      Padding="{Binding IsSidebarCollapsed, Converter={StaticResource SidebarPad}}"
                      HorizontalContentAlignment="{Binding IsSidebarCollapsed, Converter={StaticResource SidebarAlign}}"
                      ToolTip="Activity  Ctrl+7" ToolTipService.InitialShowDelay="400" Cursor="Hand">
                <StackPanel Orientation="Horizontal">
                  <ui:SymbolIcon Symbol="History20" FontSize="16" Width="18" VerticalAlignment="Center"/>
                  <TextBlock Text="Activity" Margin="10,0,0,0" VerticalAlignment="Center" FontSize="12"
                             Visibility="{Binding IsSidebarCollapsed, Converter={StaticResource InvBoolVis}}"/>
                </StackPanel>
              </Button>

              <Separator Margin="12,4"/>

              <!-- APP -->
              <TextBlock Text="APP" Style="{DynamicResource SectionLabelStyle}"
                         Visibility="{Binding IsSidebarCollapsed, Converter={StaticResource InvBoolVis}}"/>

              <Button x:Name="NavSettings" Tag="Settings" Click="Nav_Click"
                      Style="{DynamicResource NavButtonStyle}"
                      Padding="{Binding IsSidebarCollapsed, Converter={StaticResource SidebarPad}}"
                      HorizontalContentAlignment="{Binding IsSidebarCollapsed, Converter={StaticResource SidebarAlign}}"
                      ToolTip="Settings  Ctrl+9" ToolTipService.InitialShowDelay="400" Cursor="Hand">
                <StackPanel Orientation="Horizontal">
                  <ui:SymbolIcon Symbol="Settings20" FontSize="16" Width="18" VerticalAlignment="Center"/>
                  <TextBlock Text="Settings" Margin="10,0,0,0" VerticalAlignment="Center" FontSize="12"
                             Visibility="{Binding IsSidebarCollapsed, Converter={StaticResource InvBoolVis}}"/>
                </StackPanel>
              </Button>

            </StackPanel>
          </ScrollViewer>
        </DockPanel>
      </Border>

      <!-- ══ PAGE CONTENT ══ -->
      <Frame x:Name="PageFrame" Grid.Column="1"
             NavigationUIVisibility="Hidden"
             Background="{DynamicResource BgPrimaryBrush}"/>
    </Grid>

    <!-- ════════════════════ STATUS BAR ════════════════════ -->
    <Border Grid.Row="3" Background="{DynamicResource StatusBarBrush}"
            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
      <DockPanel Margin="12,0" LastChildFill="False">
        <TextBlock DockPanel.Dock="Left"
                   Text="{Binding ShellStatusText}"
                   FontSize="11"
                   Foreground="{DynamicResource TextMutedBrush}"
                   VerticalAlignment="Center"
                   TextTrimming="CharacterEllipsis"/>
        <WrapPanel DockPanel.Dock="Right" HorizontalAlignment="Right" VerticalAlignment="Center">
          <TextBlock Text="{Binding CurrentProfileStatusText}"
                     FontSize="11" Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,16,0" VerticalAlignment="Center"/>
          <TextBlock Text="{Binding LastScanTimeText}"
                     FontSize="11" Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,16,0" VerticalAlignment="Center"/>
          <TextBlock Text="{Binding FixesTodayText}"
                     FontSize="11" Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,16,0" VerticalAlignment="Center"/>
          <TextBlock Text="{Binding CurrentTimeText}"
                     FontSize="11" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"/>
        </WrapPanel>
      </DockPanel>
    </Border>

    <!-- ════════════════════ COMMAND PALETTE OVERLAY ════════════════════ -->
    <Grid Grid.Row="0" Grid.RowSpan="4" Grid.ColumnSpan="2"
          Visibility="{Binding IsCommandPaletteOpen, Converter={StaticResource BoolVis}}">
      <!-- Backdrop -->
      <Border Background="#99000000"
              MouseLeftButtonDown="CommandPaletteBg_Click"/>
      <!-- Palette card -->
      <Border Background="{DynamicResource BgCardBrush}"
              CornerRadius="10" Width="560" MaxHeight="440"
              HorizontalAlignment="Center" VerticalAlignment="Top"
              Margin="0,80,0,0"
              Effect="{DynamicResource CardShadow}">
        <DockPanel>
          <Border DockPanel.Dock="Top" Padding="16,12">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
              </Grid.ColumnDefinitions>
              <ui:SymbolIcon Grid.Column="0" Symbol="Search20" FontSize="16"
                             Foreground="{DynamicResource TextSecBrush}" Margin="0,0,10,0"
                             VerticalAlignment="Center"/>
              <TextBox Grid.Column="1" x:Name="CommandPaletteBox"
                       Text="{Binding CommandPaletteQuery, UpdateSourceTrigger=PropertyChanged}"
                       BorderThickness="0" Background="Transparent"
                       FontSize="15" VerticalContentAlignment="Center"
                       KeyDown="CommandPaletteBox_KeyDown"
                       GotFocus="CommandPaletteBox_GotFocus">
                <TextBox.Style>
                  <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                    <Setter Property="Template">
                      <Setter.Value>
                        <ControlTemplate TargetType="TextBox">
                          <Grid>
                            <TextBlock Text="Search a page, repair, workflow, tool, or support action..."
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       FontSize="15" VerticalAlignment="Center"
                                       Visibility="{Binding Text, RelativeSource={RelativeSource TemplatedParent},
                                                    Converter={StaticResource NullOrWhiteSpaceVisible}}"/>
                            <ScrollViewer x:Name="PART_ContentHost"/>
                          </Grid>
                        </ControlTemplate>
                      </Setter.Value>
                    </Setter>
                  </Style>
                </TextBox.Style>
              </TextBox>
            </Grid>
          </Border>
          <Separator DockPanel.Dock="Top"/>
          <Border DockPanel.Dock="Bottom" Padding="16,8" Background="{DynamicResource BgSurfaceBrush}">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="↵ open or run" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,12,0"/>
              <TextBlock Text="Esc closes search" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,12,0"/>
              <TextBlock Text="Ctrl+Shift+M runs safe maintenance" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
            </StackPanel>
          </Border>
          <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid>
              <ItemsControl ItemsSource="{Binding CommandPaletteResults}"
                            VirtualizingStackPanel.IsVirtualizing="True"
                            VirtualizingStackPanel.VirtualizationMode="Recycling"
                            Visibility="{Binding HasCommandPaletteResults, Converter={StaticResource BoolVis}}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <VirtualizingStackPanel/>
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Button Tag="{Binding}" Click="PaletteRun_Click"
                            HorizontalContentAlignment="Stretch" Cursor="Hand"
                            Background="Transparent" BorderThickness="0" Padding="16,8">
                      <Grid>
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="Auto"/>
                          <ColumnDefinition Width="*"/>
                          <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="{Binding Glyph}"
                                   FontFamily="{DynamicResource IconFont}"
                                   FontSize="15"
                                   Foreground="{DynamicResource TextSecBrush}"
                                   VerticalAlignment="Top"
                                   Margin="0,2,12,0"/>
                        <StackPanel Grid.Column="1">
                          <TextBlock Text="{Binding Section}" Style="{DynamicResource CardLabel}"/>
                          <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="Medium"/>
                          <TextBlock Text="{Binding Subtitle}" FontSize="11"
                                     Foreground="{DynamicResource TextSecBrush}" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Margin="12,0,0,0" VerticalAlignment="Center">
                          <TextBlock Text="{Binding Hint}" Style="{DynamicResource MetaText}" HorizontalAlignment="Right"/>
                          <ui:SymbolIcon Symbol="ArrowRight20" FontSize="14"
                                         Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                        </StackPanel>
                      </Grid>
                    </Button>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
              <Border Padding="20"
                      Visibility="{Binding HasCommandPaletteResults, Converter={StaticResource InvBoolVis}}">
                <StackPanel>
                  <TextBlock Text="Nothing matches that search yet." Style="{DynamicResource PanelTitle}"/>
                  <TextBlock Text="Try a page name, a repair keyword like network or printer, a workflow, or a Windows tool."
                             Style="{DynamicResource CardSub}" Margin="0,6,0,0"/>
                </StackPanel>
              </Border>
            </Grid>
          </ScrollViewer>
        </DockPanel>
      </Border>
    </Grid>

    <!-- ════════════════════ PRIVACY NOTICE OVERLAY ════════════════════ -->
    <Grid Grid.Row="0" Grid.RowSpan="4"
          Visibility="{Binding ShowPrivacyNotice, Converter={StaticResource BoolVis}}">
      <Border Background="#CC000000"/>
      <Border Background="{DynamicResource BgCardBrush}" CornerRadius="10"
              Width="720" HorizontalAlignment="Center" VerticalAlignment="Center"
              Padding="32" Effect="{DynamicResource CardShadow}">
        <StackPanel>
          <Image x:Name="PrivacyLogoImage" Width="48" Height="48"
                 HorizontalAlignment="Left" Margin="0,0,0,16"
                 RenderOptions.BitmapScalingMode="HighQuality"/>
          <TextBlock Text="{Binding OnboardingTitleText}" FontSize="22" FontWeight="SemiBold"
                     Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8"/>
          <TextBlock Text="{Binding OnboardingSummaryText}"
                     Foreground="{DynamicResource TextSecBrush}" FontSize="13" TextWrapping="Wrap" Margin="0,0,0,18"/>
          <Grid Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Style="{DynamicResource InfoCard}" Margin="0,0,8,0">
              <StackPanel>
                <TextBlock Text="What This Build Handles" Style="{DynamicResource PanelTitle}"/>
                <TextBlock Text="{Binding OnboardingCapabilitySummaryText}"
                           Style="{DynamicResource CardSub}" Margin="0,6,0,0" TextWrapping="Wrap"/>
              </StackPanel>
            </Border>
            <Border Grid.Column="1" Style="{DynamicResource InfoCard}" Margin="8,0,0,0">
              <StackPanel>
                <TextBlock Text="Local data and recovery" Style="{DynamicResource PanelTitle}"/>
                <TextBlock Text="{Binding OnboardingPrivacySummaryText}"
                           Style="{DynamicResource CardSub}" Margin="0,6,0,0" TextWrapping="Wrap"/>
              </StackPanel>
            </Border>
          </Grid>
          <TextBlock Text="Behavior profile" Style="{DynamicResource CardLabel}" Margin="0,0,0,8"/>
          <WrapPanel Margin="0,0,0,8" IsEnabled="{Binding CanEditBehaviorProfile}">
            <Button Content="Quiet" Tag="Quiet" Click="OnboardingProfile_Click" Style="{DynamicResource SecondaryButton}" Margin="0,0,8,8"/>
            <Button Content="Standard" Tag="Standard" Click="OnboardingProfile_Click" Style="{DynamicResource AccentButtonStyle}" Margin="0,0,8,8"/>
            <Button Content="Power User" Tag="Power User" Click="OnboardingProfile_Click" Style="{DynamicResource SecondaryButton}" Margin="0,0,8,8"
                    Visibility="{Binding CanToggleAdvancedMode, Converter={StaticResource BoolVis}}"/>
            <Button Content="Work Laptop" Tag="Work Laptop" Click="OnboardingProfile_Click" Style="{DynamicResource SecondaryButton}" Margin="0,0,8,8"/>
            <Button Content="Home PC" Tag="Home PC" Click="OnboardingProfile_Click" Style="{DynamicResource SecondaryButton}" Margin="0,0,0,8"/>
          </WrapPanel>
          <TextBlock Text="{Binding ManagedPolicySummaryText}" Style="{DynamicResource MetaText}" Margin="0,0,0,16" TextWrapping="Wrap"
                     Visibility="{Binding HasManagedRestrictions, Converter={StaticResource BoolVis}}"/>
          <Grid Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Style="{DynamicResource InfoCard}" Margin="0,0,8,0">
              <StackPanel>
                <TextBlock Text="Baseline" Style="{DynamicResource PanelTitle}"/>
                <TextBlock Text="{Binding FirstRunSummaryText}" Style="{DynamicResource CardSub}" Margin="0,6,0,0" TextWrapping="Wrap"/>
              </StackPanel>
            </Border>
            <Border Grid.Column="1" Style="{DynamicResource InfoCard}" Margin="8,0,0,0">
              <StackPanel>
                <TextBlock Text="Startup defaults" Style="{DynamicResource PanelTitle}" Margin="0,0,0,8"/>
                <CheckBox Content="Run a quick scan when this app opens"
                          IsChecked="{Binding Settings.RunQuickScanOnLaunch, Mode=TwoWay}"
                          Checked="OnboardingToggle_Changed" Unchecked="OnboardingToggle_Changed"
                          Margin="0,0,0,8"/>
                <CheckBox Content="Run the first health check after setup"
                          IsChecked="{Binding RunHealthCheckAfterSetup, Mode=TwoWay}"
                          Margin="0,0,0,8"/>
                <CheckBox Content="Keep this app in the tray when closed"
                          IsChecked="{Binding Settings.MinimizeToTray, Mode=TwoWay}"
                          Checked="OnboardingToggle_Changed" Unchecked="OnboardingToggle_Changed"
                          Margin="0,0,0,8"/>
                <CheckBox Content="Start this app with Windows"
                          IsChecked="{Binding Settings.RunAtStartup, Mode=TwoWay}"
                          Checked="OnboardingRunAtStartup_Changed" Unchecked="OnboardingRunAtStartup_Changed"/>
                <TextBlock Text="Notification mode" Style="{DynamicResource CardLabel}" Margin="0,12,0,6"/>
                <ComboBox ItemsSource="{Binding NotificationModeOptions}"
                          SelectedItem="{Binding SelectedNotificationMode, Mode=TwoWay}"
                          SelectionChanged="OnboardingToggle_Changed"
                          IsEnabled="{Binding CanEditNotificationMode}"
                          Width="180"/>
                <CheckBox Content="Prefer the safest maintenance workflow by default"
                          IsChecked="{Binding Settings.PreferSafeMaintenanceDefaults, Mode=TwoWay}"
                          Checked="OnboardingToggle_Changed" Unchecked="OnboardingToggle_Changed"
                          Margin="0,12,0,0"/>
              </StackPanel>
            </Border>
          </Grid>
          <DockPanel>
            <WrapPanel DockPanel.Dock="Left" Margin="0,0,12,0">
              <Button Content="Quick Start" Click="OnboardingQuickStart_Click"
                      Style="{DynamicResource SecondaryButton}" Margin="0,0,8,8"/>
              <Button Content="Privacy Notes" Click="OnboardingPrivacy_Click"
                      Style="{DynamicResource SecondaryButton}" Margin="0,0,8,8"/>
            </WrapPanel>
            <StackPanel DockPanel.Dock="Right" HorizontalAlignment="Right">
              <TextBlock Text="You can change every setup choice later in Settings."
                         Style="{DynamicResource CardSub}"
                         Margin="0,0,0,8"
                         HorizontalAlignment="Right"/>
              <Button Content="Finish Setup" Click="PrivacyOk_Click"
                      Style="{DynamicResource AccentButtonStyle}"
                      HorizontalAlignment="Right" Padding="24,10" Cursor="Hand"/>
            </StackPanel>
          </DockPanel>
        </StackPanel>
      </Border>
    </Grid>

    <!-- ════════════════════ SNACKBAR HOST ════════════════════ -->
    <ui:SnackbarPresenter x:Name="MainSnackbarPresenter"
                          Grid.Row="2"
                          VerticalAlignment="Bottom"
                          HorizontalAlignment="Stretch"
                          Margin="24,0,24,12"/>

    <Popup x:Name="NotificationsPopup"
           PlacementTarget="{Binding ElementName=NotificationsToggle}"
           Placement="Bottom"
           StaysOpen="False"
           AllowsTransparency="True"
           PopupAnimation="Fade"
           Closed="NotificationsPopup_Closed">
      <Border Width="380"
              Margin="0,10,12,0"
              Padding="16"
              Background="{DynamicResource BgCardBrush}"
              BorderBrush="{DynamicResource BorderBrush}"
              BorderThickness="1"
              CornerRadius="10"
              Effect="{DynamicResource CardShadow}">
        <DockPanel>
          <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <DockPanel>
              <TextBlock Text="Notifications" Style="{DynamicResource PanelTitle}"/>
              <TextBlock DockPanel.Dock="Right"
                         Text="{Binding NotificationSummaryText}"
                         Style="{DynamicResource CardSub}"
                         VerticalAlignment="Center"/>
            </DockPanel>
            <TextBlock Text="Recent alerts and fast actions stay here so the rest of the app can stay calm."
                       Style="{DynamicResource CardSub}"
                       TextWrapping="Wrap"
                       Margin="0,4,0,0"/>
          </StackPanel>

          <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,12,0,0">
            <Button Content="Open Support" Click="NotificationOpenSupport_Click"
                    Style="{DynamicResource SecondaryButton}" Margin="0,0,8,0"/>
            <Button Content="Clear All" Click="NotificationClearAll_Click"
                    Style="{DynamicResource SecondaryButton}"/>
          </StackPanel>

          <ScrollViewer MaxHeight="420" VerticalScrollBarVisibility="Auto">
            <StackPanel>
              <ItemsControl ItemsSource="{Binding NotificationEntries}"
                            Visibility="{Binding HasNotifications, Converter={StaticResource BoolVis}}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Style="{DynamicResource FixCard}" Padding="12" Margin="0,0,0,8">
                      <Grid>
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="4"/>
                          <ColumnDefinition Width="*"/>
                          <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="{Binding Level, Converter={StaticResource NotifColor}}" CornerRadius="2" Margin="0,0,10,0"/>
                        <StackPanel Grid.Column="1">
                          <TextBlock Text="{Binding Title}" FontWeight="SemiBold"/>
                          <TextBlock Text="{Binding Message}" Style="{DynamicResource CardSub}" TextWrapping="Wrap" Margin="0,3,0,0"/>
                          <TextBlock Text="{Binding Timestamp, Converter={StaticResource RelDate}}" Style="{DynamicResource MetaText}" Margin="0,6,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Margin="12,0,0,0">
                          <Button Content="Read" Tag="{Binding}" Click="NotificationRead_Click"
                                  Style="{DynamicResource SecondaryButton}" Margin="0,0,0,6"/>
                          <Button Content="Dismiss" Tag="{Binding}" Click="NotificationDismiss_Click"
                                  Style="{DynamicResource SecondaryButton}" Margin="0,0,0,6"/>
                          <Button Content="Run Fix"
                                  Tag="{Binding ActionFixId}"
                                  Click="NotificationRunFix_Click"
                                  Style="{DynamicResource SecondaryButton}"
                                  Visibility="{Binding ActionFixId, Converter={StaticResource NullCollapsed}}"/>
                        </StackPanel>
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
              <TextBlock Text="No active alerts in this session."
                         Style="{DynamicResource CardSub}"
                         Visibility="{Binding HasNotifications, Converter={StaticResource InvBoolVis}}"/>
            </StackPanel>
          </ScrollViewer>
        </DockPanel>
      </Border>
    </Popup>

  </Grid>
</ui:FluentWindow>
