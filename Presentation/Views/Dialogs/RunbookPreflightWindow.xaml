<Window x:Class="HelpDesk.Presentation.Views.Dialogs.RunbookPreflightWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:automation="clr-namespace:System.Windows.Automation;assembly=PresentationCore"
        xmlns:h="clr-namespace:HelpDesk.Presentation.Helpers"
        Title="Review Workflow Before Running"
        Width="480"
        MaxWidth="480"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="{DynamicResource BgPrimaryBrush}">
  <Window.Resources>
    <h:InverseBoolToVisConverter x:Key="InvBoolVis"/>
  </Window.Resources>
  <Border Background="{DynamicResource BgPrimaryBrush}" Padding="24"
          automation:AutomationProperties.AutomationId="Runbook_Preflight_Panel">
    <StackPanel>
      <TextBlock Text="{Binding Runbook.Title}" Style="{DynamicResource PageTitle}" TextWrapping="Wrap"/>
      <TextBlock Text="{Binding Runbook.Description}" Style="{DynamicResource CardSub}" Margin="0,8,0,16" TextWrapping="Wrap"/>

      <Border Background="{DynamicResource BgCard2Brush}" CornerRadius="10" Padding="14,12" Margin="0,0,0,14">
        <StackPanel>
          <TextBlock Text="What this will do" Style="{DynamicResource CardLabel}"/>
          <ItemsControl ItemsSource="{Binding StepTitles}"
                        Margin="0,8,0,0"
                        automation:AutomationProperties.AutomationId="Runbook_Preflight_WhatItDoes_List">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <DockPanel Margin="0,0,0,6">
                  <TextBlock Text="•" Margin="0,0,8,0" Foreground="{DynamicResource TextSecBrush}"/>
                  <TextBlock Text="{Binding}" Style="{DynamicResource CardSub}" TextWrapping="Wrap"/>
                </DockPanel>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </Border>

      <Border Background="{DynamicResource BgCard2Brush}" CornerRadius="10" Padding="14,12" Margin="0,0,0,14">
        <StackPanel>
          <DockPanel>
            <TextBlock Text="What cannot be undone" Style="{DynamicResource CardLabel}"/>
            <Ellipse Width="10" Height="10" Fill="{DynamicResource AccentGreenBrush}" HorizontalAlignment="Right"
                     Visibility="{Binding HasIrreversibleActions, Converter={StaticResource InvBoolVis}}"/>
          </DockPanel>
          <ItemsControl ItemsSource="{Binding IrreversibleItems}"
                        Margin="0,8,0,0"
                        automation:AutomationProperties.AutomationId="Runbook_Preflight_Irreversible_List">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <DockPanel Margin="0,0,0,6">
                  <TextBlock Text="•" Margin="0,0,8,0" Foreground="{DynamicResource TextSecBrush}"/>
                  <TextBlock Text="{Binding}" Style="{DynamicResource CardSub}" TextWrapping="Wrap"/>
                </DockPanel>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </Border>

      <Border Background="{DynamicResource BgCard2Brush}" CornerRadius="10" Padding="14,12" Margin="0,0,0,18">
        <StackPanel>
          <TextBlock Text="Estimated time" Style="{DynamicResource CardLabel}"/>
          <TextBlock Text="{Binding Runbook.EstimatedDurationLabel}" Style="{DynamicResource CardSub}" Margin="0,6,0,0"/>
        </StackPanel>
      </Border>

      <WrapPanel HorizontalAlignment="Right">
        <Button Content="Cancel"
                Click="Cancel_Click"
                Style="{DynamicResource SecondaryButton}"
                Margin="0,0,8,0"
                IsCancel="True"
                automation:AutomationProperties.AutomationId="Runbook_Preflight_Cancel"/>
        <Button Content="I understand, continue"
                Click="Confirm_Click"
                Style="{DynamicResource AccentButtonStyle}"
                IsDefault="True"
                automation:AutomationProperties.AutomationId="Runbook_Preflight_Confirm"/>
      </WrapPanel>
    </StackPanel>
  </Border>
</Window>
