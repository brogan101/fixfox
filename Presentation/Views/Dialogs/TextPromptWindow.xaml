<Window x:Class="HelpDesk.Presentation.Views.Dialogs.TextPromptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Add Site"
        Width="420"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource BgPrimaryBrush}">
  <Border Padding="20">
    <StackPanel>
      <TextBlock Text="{Binding Prompt, RelativeSource={RelativeSource AncestorType=Window}}"
                 TextWrapping="Wrap"
                 Margin="0,0,0,12"
                 Style="{DynamicResource CardSub}"/>
      <TextBox x:Name="ValueTextBox"
               MinWidth="320"
               Margin="0,0,0,16"/>
      <DockPanel>
        <Button DockPanel.Dock="Right"
                Content="{Binding ConfirmLabel, RelativeSource={RelativeSource AncestorType=Window}}"
                IsDefault="True"
                Click="Confirm_Click"
                Style="{DynamicResource AccentButtonStyle}"/>
        <Button DockPanel.Dock="Right"
                Content="Cancel"
                Margin="0,0,8,0"
                IsCancel="True"
                Style="{DynamicResource SecondaryButton}"/>
      </DockPanel>
    </StackPanel>
  </Border>
</Window>
